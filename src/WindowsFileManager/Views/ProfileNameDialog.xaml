<Window x:Class="WindowsFileManager.Views.ProfileNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="DialogRoot"
        Title="Profile"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#FAFAFA">

    <Border BorderBrush="#CFD8DC" BorderThickness="1" Padding="20,16">
        <StackPanel>
            <TextBlock x:Name="HeadlineText" Text="Profile Name"
                       FontSize="14" FontWeight="Bold" Foreground="#263238" Margin="0,0,0,4" />

            <TextBlock x:Name="PromptText" Text="Enter a name for this profile."
                       FontSize="11.5" Foreground="#546E7A" Margin="0,0,0,12"
                       TextWrapping="Wrap" />

            <TextBox x:Name="NameInput"
                     FontSize="13" Padding="8,6"
                     BorderBrush="#B0BEC5" BorderThickness="1"
                     TextChanged="NameInput_TextChanged"
                     KeyDown="NameInput_KeyDown" />

            <TextBlock x:Name="ValidationText"
                       FontSize="11" FontStyle="Italic"
                       Foreground="#C62828" Margin="0,6,0,0"
                       TextWrapping="Wrap"
                       Visibility="Collapsed" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button x:Name="CancelButton" Content="Cancel"
                        Padding="16,6" MinWidth="80" FontSize="12"
                        Cursor="Hand" IsCancel="True"
                        Click="Cancel_Click" />
                <Button x:Name="OkButton" Content="OK"
                        Padding="16,6" Margin="8,0,0,0" MinWidth="80" FontSize="12"
                        Cursor="Hand" FontWeight="SemiBold"
                        Background="#1565C0" Foreground="White"
                        BorderBrush="#0D47A1" BorderThickness="1"
                        IsDefault="True"
                        Click="Ok_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
