<Window x:Class="WindowsFileManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WindowsFileManager.ViewModels"
        xmlns:helpers="clr-namespace:WindowsFileManager.Helpers"
        Title="Folder File Manager"
        Height="900" Width="1600"
        MinHeight="500" MinWidth="1000"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <helpers:InverseBoolConverter x:Key="InverseBool" />
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <helpers:MiniPreviewConverter x:Key="MiniPreview" />
        <helpers:FileTypeIconConverter x:Key="FileTypeIcon" />

        <!-- Help Button Style: small ? circle that shows a popup on click -->
        <Style x:Key="HelpButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#1565C0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Circle" Width="16" Height="16" CornerRadius="8"
                                    Background="#E3F2FD" BorderBrush="#90CAF9" BorderThickness="1">
                                <TextBlock Text="?" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="10" FontWeight="Bold" Foreground="#1565C0" Margin="0,-1,0,0" />
                            </Border>
                            <Popup x:Name="HelpPopup" IsOpen="{Binding IsChecked, RelativeSource={RelativeSource TemplatedParent}}"
                                   StaysOpen="False" Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade">
                                <Border Background="#FFFDE7" BorderBrush="#FFD54F" BorderThickness="1"
                                        CornerRadius="6" Padding="12,10" MaxWidth="380">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.15" BlurRadius="8" ShadowDepth="2" />
                                    </Border.Effect>
                                    <TextBlock TextWrapping="Wrap" FontSize="11.5" FontWeight="Normal"
                                               Foreground="#333333" LineHeight="18"
                                               helpers:FormattedTextBehavior.FormattedText="{TemplateBinding Tag}" />
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Circle" Property="Background" Value="#BBDEFB" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Circle" Property="Background" Value="#1565C0" />
                                <Setter TargetName="Circle" Property="BorderBrush" Value="#0D47A1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Column 0: Target Folders + Tabs -->
        <Grid Grid.Column="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Row 0: Target Folders + Exclude Folders (50/50 side by side) -->
        <Grid Grid.Row="0" Margin="4,4,4,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: Target Folders -->
            <Border Grid.Column="0" BorderBrush="#C0C0C0" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,2,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header row -->
                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <TextBlock Text="Target Folders" FontWeight="Bold" FontSize="12"
                                   VerticalAlignment="Center" HorizontalAlignment="Left" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <CheckBox Content="Include subdirectories"
                                      IsChecked="{Binding IncludeSubdirectories}"
                                      IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBool}}"
                                      VerticalAlignment="Center" Margin="0,0,4,0" />
                            <ToggleButton Style="{StaticResource HelpButtonStyle}"
                                          Tag="&lt;h&gt;WHERE TO SCAN&lt;/h&gt;&#x0a;Add folders that may contain duplicate files.&#x0a;&#x0a;&lt;b&gt;Include subdirectories&lt;/b&gt; = scan all nested folders too&#x0a;&lt;b&gt;Multiple folders&lt;/b&gt; = compare files across different locations&#x0a;&#x0a;&lt;h&gt;How it works:&lt;/h&gt; Files are compared by &lt;b&gt;content hash (SHA-256)&lt;/b&gt;, not by name. Two files with different names but identical content are detected as duplicates." />
                        </StackPanel>
                    </Grid>

                    <!-- Path input + buttons -->
                    <Grid Grid.Row="1" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" Text="{Binding NewFolderPath, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="6,4" VerticalContentAlignment="Center"
                                 IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBool}}"
                                 helpers:TextBoxEnterKeyBehavior.Command="{Binding AddFolderByPathCommand}" />

                        <Button Grid.Column="1" Content="Add"
                                Command="{Binding AddFolderByPathCommand}"
                                Padding="12,4" Margin="6,0,0,0"
                                IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBool}}" />

                        <Button Grid.Column="2" Content="Browse..."
                                Command="{Binding AddFolderCommand}"
                                Padding="12,4" Margin="6,0,0,0"
                                IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBool}}" />
                    </Grid>

                    <!-- Folder chips -->
                    <ItemsControl Grid.Row="2" ItemsSource="{Binding TargetPaths}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="3" Padding="6,3" Margin="0,0,6,4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E8EAF6" />
                                                <Setter Property="Opacity" Value="1" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                        <Setter Property="Background" Value="#EEEEEE" />
                                                        <Setter Property="Opacity" Value="0.6" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox IsChecked="{Binding IsEnabled}" VerticalAlignment="Center"
                                                      Margin="0,0,4,0" Cursor="Hand"
                                                      ToolTip="Enable or disable this path temporarily" />
                                            <TextBlock Text="{Binding Value}" VerticalAlignment="Center"
                                                       FontSize="11" Foreground="#333333"
                                                       ToolTip="{Binding Value}" />
                                            <Button Content="✕"
                                                    Command="{Binding DataContext.RemoveFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="2,0" Margin="6,0,0,0"
                                                    FontSize="9" Foreground="#C62828" Cursor="Hand"
                                                    Background="Transparent" BorderThickness="0"
                                                    ToolTip="Remove this folder" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                </Grid>
            </Border>

            <!-- Right: Exclude Folders -->
            <Border Grid.Column="1" BorderBrush="#C0C0C0" BorderThickness="1" CornerRadius="4" Padding="8" Margin="2,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header row -->
                    <TextBlock Grid.Row="0" Text="Exclude Folders" FontWeight="Bold" FontSize="12"
                               Foreground="#E65100" Margin="0,0,0,6" />

                    <!-- Input + add -->
                    <Grid Grid.Row="1" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding NewExcludeFolderName, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="6,4" FontSize="11" VerticalContentAlignment="Center"
                                 helpers:TextBoxEnterKeyBehavior.Command="{Binding AddExcludeFolderCommand}" />
                        <Button Grid.Column="1" Content="+ Add" Command="{Binding AddExcludeFolderCommand}"
                                Padding="8,4" Margin="6,0,0,0" FontSize="11" Cursor="Hand"
                                FontWeight="SemiBold" Foreground="#E65100" />
                        <ToggleButton Grid.Column="2" Style="{StaticResource HelpButtonStyle}" Margin="6,0,0,0"
                                      Tag="&lt;h&gt;EXCLUDE FOLDER NAMES&lt;/h&gt;&#x0a;Skip folders with these names during scanning.&#x0a;&#x0a;Matching is by &lt;b&gt;folder name only&lt;/b&gt; (not full path), case-insensitive.&#x0a;Any subfolder matching the name is skipped entirely.&#x0a;&#x0a;&lt;h&gt;Common examples:&lt;/h&gt;&#x0a;&lt;b&gt;node_modules&lt;/b&gt; — JavaScript dependencies&#x0a;&lt;b&gt;.git&lt;/b&gt; — Git internals&#x0a;&lt;b&gt;bin&lt;/b&gt; / &lt;b&gt;obj&lt;/b&gt; — Build output&#x0a;&lt;b&gt;__pycache__&lt;/b&gt; — Python cache" />
                    </Grid>

                    <!-- Exclude folder chips -->
                    <ItemsControl Grid.Row="2" ItemsSource="{Binding ExcludeFolderNames}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="3" Padding="6,2" Margin="0,0,6,4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FFE0B2" />
                                            <Setter Property="Opacity" Value="1" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                    <Setter Property="Background" Value="#EEEEEE" />
                                                    <Setter Property="Opacity" Value="0.6" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding IsEnabled}" VerticalAlignment="Center"
                                                  Margin="0,0,4,0" Cursor="Hand"
                                                  ToolTip="Enable or disable this exclusion temporarily" />
                                        <TextBlock Text="{Binding Value}" VerticalAlignment="Center"
                                                   FontSize="11" Foreground="#BF360C" FontWeight="SemiBold" />
                                        <Button Content="✕"
                                                Command="{Binding DataContext.RemoveExcludeFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Padding="2,0" Margin="6,0,0,0"
                                                FontSize="9" Foreground="#C62828" Cursor="Hand"
                                                Background="Transparent" BorderThickness="0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>

        <!-- Row 1: Feature Tabs -->
        <TabControl Grid.Row="1" Margin="4,0,4,4" SelectionChanged="TabControl_SelectionChanged">

            <!-- Tab 1: Folder Control -->
            <TabItem Header="Folder Control">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Row 0: Search patterns (configurable chip list) -->
                    <Border Grid.Row="0" Background="#E8EAF6" CornerRadius="4" Padding="8,2" Margin="0,0,0,4"
                            BorderBrush="#C5CAE9" BorderThickness="1">
                        <StackPanel>
                            <WrapPanel Orientation="Horizontal">
                                <!-- Label -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2" VerticalAlignment="Center">
                                    <TextBlock Text="Folder Search" FontSize="11" FontWeight="Bold" Foreground="#1565C0"
                                               VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <ToggleButton Style="{StaticResource HelpButtonStyle}"
                                                  Tag="&lt;h&gt;FOLDER SEARCH&lt;/h&gt;&#x0a;Search for folders by name across all target paths.&#x0a;&#x0a;&lt;b&gt;How it works:&lt;/b&gt;&#x0a;1. Add folder name patterns to the list&#x0a;2. Click &lt;b&gt;Search&lt;/b&gt; to find matching folders&#x0a;3. Results show all folders whose name contains the pattern&#x0a;&#x0a;&lt;b&gt;Scope:&lt;/b&gt; Uses the same Target Folders and Exclude Folders from the main tab.&#x0a;&lt;b&gt;Matching:&lt;/b&gt; Case-insensitive contains match.&#x0a;&#x0a;&lt;h&gt;Tip:&lt;/h&gt; Enable/disable patterns to quickly compare different search sets." />
                                    <Border Width="1" Background="#C5CAE9" Margin="8,2" />
                                </StackPanel>

                                <!-- Input -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2" VerticalAlignment="Center">
                                    <ComboBox ItemsSource="{Binding FolderMatchTypes}"
                                              SelectedItem="{Binding NewFolderSearchMatchType}"
                                              FontSize="11" Width="92" VerticalContentAlignment="Center"
                                              Margin="0,0,2,0" />
                                    <ToggleButton Style="{StaticResource HelpButtonStyle}"
                                                  Margin="0,0,4,0"
                                                  Tag="&lt;h&gt;MATCH TYPES&lt;/h&gt;&#x0a;&#x0a;&lt;b&gt;Include&lt;/b&gt; — folder name &lt;b&gt;contains&lt;/b&gt; the text (partial match)&#x0a;Example: &quot;log&quot; matches &lt;b&gt;log&lt;/b&gt;s, change&lt;b&gt;log&lt;/b&gt;, &lt;b&gt;log&lt;/b&gt;-backup&#x0a;&#x0a;&lt;b&gt;Match&lt;/b&gt; — folder name &lt;b&gt;exactly equals&lt;/b&gt; the text&#x0a;Example: &quot;bin&quot; matches only &lt;b&gt;bin&lt;/b&gt;, not binary or recycle-bin&#x0a;&#x0a;&lt;b&gt;Contains&lt;/b&gt; — folder has a &lt;b&gt;child item&lt;/b&gt; (file/subfolder) inside it&#x0a;Example: &quot;.git&quot; finds git repos, &quot;*.sln&quot; finds .NET solutions&#x0a;Supports wildcards: &quot;*.py&quot;, &quot;*.csproj&quot;, &quot;*.json&quot;&#x0a;&#x0a;&lt;b&gt;Exclude&lt;/b&gt; — folder name does &lt;b&gt;NOT contain&lt;/b&gt; the text (opposite of Include)&#x0a;Example: &quot;test&quot; skips folders with &quot;test&quot; in the name&#x0a;&#x0a;&lt;b&gt;Mismatch&lt;/b&gt; — folder name does &lt;b&gt;NOT equal&lt;/b&gt; the text (opposite of Match)&#x0a;Example: &quot;bin&quot; skips only the exact &quot;bin&quot; folder&#x0a;&#x0a;&lt;h&gt;Combining:&lt;/h&gt; All enabled patterns use AND logic.&#x0a;Example: Contains &quot;.git&quot; + Exclude &quot;node_modules&quot;&#x0a;= git repos whose name doesn't include &quot;node_modules&quot;" />
                                    <TextBlock Text="name:" FontWeight="SemiBold" FontSize="11"
                                               Foreground="#333333" VerticalAlignment="Center" Margin="0,0,4,0" />
                                    <Grid Width="180">
                                        <TextBox x:Name="FolderPatternInput"
                                                 Text="{Binding NewFolderSearchPattern, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="4,3" FontSize="11" VerticalContentAlignment="Center"
                                                 helpers:TextBoxEnterKeyBehavior.Command="{Binding AddFolderSearchPatternCommand}" />
                                        <TextBlock Text="folder name or pattern..."
                                                   Padding="6,4" FontSize="11" Foreground="#AAAAAA"
                                                   VerticalAlignment="Center" IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=FolderPatternInput}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <Button Content="+ Add" Command="{Binding AddFolderSearchPatternCommand}"
                                            CommandParameter="{Binding Text, ElementName=FolderPatternInput}"
                                            Padding="8,3" Margin="4,0,0,0" FontSize="11" Cursor="Hand"
                                            FontWeight="SemiBold" Foreground="#1565C0" />
                                    <Border Width="1" Background="#C5CAE9" Margin="8,2" />
                                </StackPanel>

                                <!-- Search action + status -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2" VerticalAlignment="Center">
                                    <Button Command="{Binding SearchFoldersCommand}"
                                            Padding="10,5" FontSize="12" Cursor="Hand"
                                            FontWeight="Bold" Foreground="White"
                                            BorderThickness="0">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="#1565C0" />
                                                <Setter Property="Content" Value="▶ Search" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="SearchBorder" Background="{TemplateBinding Background}"
                                                                    CornerRadius="4" Padding="{TemplateBinding Padding}"
                                                                    BorderThickness="0">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="SearchBorder" Property="Background" Value="#0D47A1" />
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter TargetName="SearchBorder" Property="Background" Value="#B0BEC5" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFolderSearching}" Value="True">
                                                        <Setter Property="Content" Value="⏳ Searching…" />
                                                        <Setter Property="Background" Value="#90A4AE" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <ToggleButton Style="{StaticResource HelpButtonStyle}" Margin="6,0,0,0"
                                                  Tag="&lt;h&gt;SEARCH&lt;/h&gt;&#x0a;Click &lt;b&gt;Search&lt;/b&gt; to find folders matching your patterns.&#x0a;&#x0a;&lt;b&gt;Requirements:&lt;/b&gt;&#x0a;• At least one &lt;b&gt;enabled&lt;/b&gt; target folder (shared from main tab)&#x0a;&#x0a;&lt;b&gt;No patterns?&lt;/b&gt; Returns &lt;b&gt;all folders&lt;/b&gt; (no filtering).&#x0a;&#x0a;&lt;b&gt;How it works:&lt;/b&gt;&#x0a;1. Scans all enabled target folders recursively&#x0a;2. Matches folders against enabled patterns (or returns all)&#x0a;3. Skips excluded folders (shared from main tab)&#x0a;4. Results appear in the list below&#x0a;&#x0a;&lt;h&gt;Then:&lt;/h&gt; Use the &lt;b&gt;Action&lt;/b&gt; section to select and delete/move found folders." />
                                    <Button Content="⏹ Stop" Command="{Binding StopFolderSearchCommand}"
                                            Padding="8,3" Margin="8,0,0,0" FontSize="11" Cursor="Hand"
                                            FontWeight="SemiBold" Foreground="#C62828"
                                            Visibility="{Binding IsFolderSearching, Converter={StaticResource BoolToVisibility}}"
                                            ToolTip="Cancel the running search" />
                                    <Button Content="✕ Clear" Command="{Binding ClearFolderSearchCommand}"
                                            Padding="8,3" Margin="8,0,0,0" FontSize="11" Cursor="Hand"
                                            FontWeight="SemiBold" Foreground="#C62828"
                                            ToolTip="Clear search results and discovered subfolders" />
                                    <ProgressBar Width="120" Height="8" Margin="8,0,0,0"
                                                 IsIndeterminate="{Binding IsFolderSearching}"
                                                 Visibility="{Binding IsFolderSearching, Converter={StaticResource BoolToVisibility}}"
                                                 Foreground="#1565C0" Background="#E3F2FD"
                                                 BorderThickness="0" VerticalAlignment="Center" />
                                    <TextBlock FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#666666" />
                                                <Setter Property="Text" Value="{Binding FolderSearchStatus}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFolderSearching}" Value="True">
                                                        <Setter Property="Foreground" Value="#1565C0" />
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding FolderPatternAddStatus}" Foreground="#C62828"
                                               FontSize="11" FontStyle="Italic" VerticalAlignment="Center"
                                               Margin="12,0,0,0" />
                                </StackPanel>
                            </WrapPanel>

                            <!-- Search pattern chips -->
                            <ItemsControl ItemsSource="{Binding FolderSearchPatterns}" Margin="0,4,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="3" Padding="6,3" Margin="0,0,6,4">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#C5CAE9" />
                                                    <Setter Property="BorderBrush" Value="#7986CB" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Setter Property="Opacity" Value="1" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                            <Setter Property="Background" Value="#EEEEEE" />
                                                            <Setter Property="BorderBrush" Value="#D0D0D0" />
                                                            <Setter Property="Opacity" Value="0.6" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <CheckBox IsChecked="{Binding IsEnabled}" VerticalAlignment="Center"
                                                          Margin="0,0,4,0" Cursor="Hand"
                                                          ToolTip="Enable or disable this search pattern" />
                                                <!-- Priority number -->
                                                <Border CornerRadius="3" Padding="5,1" Margin="0,0,4,0"
                                                        VerticalAlignment="Center" Width="20">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#424242" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                    <Setter Property="Background" Value="#BDBDBD" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Priority}" FontSize="9" FontWeight="Bold"
                                                               Foreground="White" HorizontalAlignment="Center" />
                                                </Border>
                                                <!-- Move up/down -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,4,0" VerticalAlignment="Center">
                                                    <Button Command="{Binding DataContext.MoveSearchPatternUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}" Cursor="Hand" ToolTip="Move up (higher priority)">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="UpBorder" Background="#E0E0E0" CornerRadius="2,0,0,2"
                                                                        Padding="3,1" BorderThickness="0">
                                                                    <TextBlock Text="▲" FontSize="8" Foreground="#555555"
                                                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="UpBorder" Property="Background" Value="#1565C0" />
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                    <Button Command="{Binding DataContext.MoveSearchPatternDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}" Cursor="Hand" ToolTip="Move down (lower priority)">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="DownBorder" Background="#E0E0E0" CornerRadius="0,2,2,0"
                                                                        Padding="3,1" BorderThickness="0">
                                                                    <TextBlock Text="▼" FontSize="8" Foreground="#555555"
                                                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="DownBorder" Property="Background" Value="#1565C0" />
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </StackPanel>
                                                <!-- Match type badge -->
                                                <ComboBox ItemsSource="{Binding DataContext.FolderMatchTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          SelectedItem="{Binding MatchType}"
                                                          FontSize="9" Width="80" VerticalContentAlignment="Center"
                                                          Margin="0,0,4,0" />
                                                <!-- Editable pattern text -->
                                                <TextBox Text="{Binding Pattern, UpdateSourceTrigger=LostFocus}"
                                                         MinWidth="80" Padding="4,2" FontSize="11"
                                                         FontWeight="SemiBold" Foreground="#283593"
                                                         VerticalContentAlignment="Center"
                                                         BorderThickness="0,0,0,1.5" BorderBrush="#7986CB"
                                                         Background="Transparent"
                                                         ToolTip="Click to edit pattern" />
                                                <Button Content="✕"
                                                        Command="{Binding DataContext.RemoveFolderSearchPatternCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Padding="2,0" Margin="6,0,0,0"
                                                        FontSize="9" Foreground="#C62828" Cursor="Hand"
                                                        Background="Transparent" BorderThickness="0" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Row 1: Results list -->
                    <ListView Grid.Row="1" ItemsSource="{Binding FolderSearchResults}"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              BorderThickness="1" BorderBrush="#E0E0E0"
                              GridViewColumnHeader.Click="FolderResults_ColumnHeaderClick">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="30">
                                    <GridViewColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding DataContext.AreAllFoldersSelected, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      Cursor="Hand" ToolTip="Select / deselect all" />
                                        </DataTemplate>
                                    </GridViewColumn.HeaderTemplate>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected}" Cursor="Hand" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Folder Name" Width="200"
                                                DisplayMemberBinding="{Binding FolderName}" />
                                <GridViewColumn Header="Size" Width="90"
                                                DisplayMemberBinding="{Binding TotalSizeDisplay}" />
                                <GridViewColumn Header="Full Path" Width="600">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <Hyperlink Command="{Binding DataContext.OpenFolderLocationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           CommandParameter="{Binding FullPath}"
                                                           Foreground="#1565C0">
                                                    <Run Text="{Binding FullPath, Mode=OneWay}" />
                                                </Hyperlink>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </TabItem>

            <!-- Tab 2: Duplicates Control -->
            <TabItem Header="Duplicates Control">
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="400" />
        </Grid.ColumnDefinitions>

        <!-- Left Column: Controls + Results -->
        <Grid Grid.Column="0" Margin="0,0,8,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Row 0: Action Buttons + Progress -->
            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Scan for Duplicates"
                            Command="{Binding ScanCommand}"
                            Padding="16,6" FontWeight="SemiBold"
                            Margin="0,0,8,0" />

                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Padding="16,6"
                            Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibility}}" />

                    <TextBlock Text="{Binding FilesScanned, StringFormat='Files scanned: {0}'}"
                               VerticalAlignment="Center" Margin="16,0,0,0"
                               Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibility}}" />

                    <ToggleButton Style="{StaticResource HelpButtonStyle}" Margin="16,0,0,0"
                                  Tag="&lt;h&gt;SCAN &amp; DISPLAY OPTIONS&lt;/h&gt;&#x0a;&#x0a;&lt;b&gt;Mini Preview&lt;/b&gt; = show small thumbnails inline in the list&#x0a;&lt;b&gt;File Preview&lt;/b&gt; = show full preview panel when clicking a file&#x0a;&lt;b&gt;Auto Play&lt;/b&gt; = auto-play video/audio in preview&#x0a;&#x0a;After scanning, use &lt;b&gt;Filters&lt;/b&gt; to narrow results and &lt;b&gt;Actions&lt;/b&gt; to select files for deletion or moving." />

                    <ToggleButton IsChecked="{Binding IsMiniPreview}"
                                  VerticalAlignment="Center" FontSize="11" Padding="8,3" Margin="16,0,0,0" Cursor="Hand"
                                  ToolTip="Show inline thumbnail in the duplicate list">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Content" Value="Mini Preview" />
                                <Setter Property="Foreground" Value="#555555" />
                                <Setter Property="Background" Value="#F5F5F5" />
                                <Setter Property="BorderBrush" Value="#CCCCCC" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="Content" Value="✦ Mini Preview" />
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter Property="Background" Value="#0277BD" />
                                        <Setter Property="BorderBrush" Value="#01579B" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E1F5FE" />
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsChecked" Value="True" />
                                            <Condition Property="IsMouseOver" Value="True" />
                                        </MultiTrigger.Conditions>
                                        <Setter Property="Background" Value="#0288D1" />
                                    </MultiTrigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>

                    <ToggleButton IsChecked="{Binding IsAutoPreview}"
                                  VerticalAlignment="Center" FontSize="11" Padding="8,3" Margin="4,0,0,0" Cursor="Hand"
                                  ToolTip="Show full file preview panel when clicking a group">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Content" Value="File Preview" />
                                <Setter Property="Foreground" Value="#555555" />
                                <Setter Property="Background" Value="#F5F5F5" />
                                <Setter Property="BorderBrush" Value="#CCCCCC" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="Content" Value="✦ File Preview" />
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter Property="Background" Value="#0277BD" />
                                        <Setter Property="BorderBrush" Value="#01579B" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E1F5FE" />
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsChecked" Value="True" />
                                            <Condition Property="IsMouseOver" Value="True" />
                                        </MultiTrigger.Conditions>
                                        <Setter Property="Background" Value="#0288D1" />
                                    </MultiTrigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>

                    <ToggleButton IsChecked="{Binding IsAnalyticsVisible}"
                                  VerticalAlignment="Center" FontSize="11" Padding="8,3" Margin="4,0,0,0" Cursor="Hand"
                                  ToolTip="Show or hide the analytics dashboard panel">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Content" Value="Analytics" />
                                <Setter Property="Foreground" Value="#555555" />
                                <Setter Property="Background" Value="#F5F5F5" />
                                <Setter Property="BorderBrush" Value="#CCCCCC" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="Content" Value="✦ Analytics" />
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter Property="Background" Value="#0277BD" />
                                        <Setter Property="BorderBrush" Value="#01579B" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E1F5FE" />
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsChecked" Value="True" />
                                            <Condition Property="IsMouseOver" Value="True" />
                                        </MultiTrigger.Conditions>
                                        <Setter Property="Background" Value="#0288D1" />
                                    </MultiTrigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>

                    <ToggleButton IsChecked="{Binding IsAutoPlay}"
                                  VerticalAlignment="Center" FontSize="11" Padding="8,3" Margin="4,0,0,0" Cursor="Hand"
                                  ToolTip="Auto-play video/audio. When off, video shows first frame.">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Content" Value="Auto Play" />
                                <Setter Property="Foreground" Value="#555555" />
                                <Setter Property="Background" Value="#F5F5F5" />
                                <Setter Property="BorderBrush" Value="#CCCCCC" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="Content" Value="✦ Auto Play" />
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter Property="Background" Value="#0277BD" />
                                        <Setter Property="BorderBrush" Value="#01579B" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E1F5FE" />
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsChecked" Value="True" />
                                            <Condition Property="IsMouseOver" Value="True" />
                                        </MultiTrigger.Conditions>
                                        <Setter Property="Background" Value="#0288D1" />
                                    </MultiTrigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                </StackPanel>

                <ProgressBar Height="6" Margin="0,6,0,0"
                             IsIndeterminate="{Binding IsScanning}"
                             Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>

            <!-- Row 1: Workflow Panels + Duplicate Groups List -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Row 0: Base Filters (inline — sort + file type controls + size/dup filters) -->
                <Border Grid.Row="0" Background="#F0F4FF" CornerRadius="4" Padding="8,2" Margin="0,0,0,4"
                        BorderBrush="#C5CAE9" BorderThickness="1">
                    <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Title -->
                        <StackPanel Orientation="Horizontal" Margin="0,2,8,2" VerticalAlignment="Center">
                            <TextBlock Text="Base Filters" FontWeight="Bold" FontSize="11"
                                       Foreground="#1565C0" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <ToggleButton Style="{StaticResource HelpButtonStyle}"
                                          Tag="&lt;h&gt;BASE FILTERS&lt;/h&gt;&#x0a;Quick filters to narrow down duplicate results.&#x0a;&#x0a;&lt;b&gt;Sort&lt;/b&gt; — order groups by size, count, type, or name&#x0a;&lt;b&gt;Types&lt;/b&gt; — show/hide groups by file extension&#x0a;&lt;b&gt;Min size&lt;/b&gt; — hide files smaller than threshold&#x0a;&lt;b&gt;Min dups&lt;/b&gt; — hide groups with fewer than N copies&#x0a;&#x0a;&lt;h&gt;Tip:&lt;/h&gt; These filters work instantly on the current scan results. Use &lt;b&gt;Custom Rules&lt;/b&gt; below for pattern-based selection." />
                            <Border Width="1" Background="#C5CAE9" Margin="8,2" />
                        </StackPanel>

                        <!-- Sort + Group count -->
                        <StackPanel Orientation="Horizontal" Margin="0,2,8,2" VerticalAlignment="Center">
                            <TextBlock Text="Sort:" FontWeight="SemiBold" FontSize="11"
                                       Foreground="#666666" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <ComboBox ItemsSource="{Binding SortOptions}"
                                      SelectedItem="{Binding SelectedSortOption}"
                                      Width="155" FontSize="11" VerticalContentAlignment="Center" />
                            <Border Width="1" Background="#D0D0D0" Margin="8,2" />
                            <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#888888">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="Showing {0} of {1} groups">
                                        <Binding Path="FilteredGroupCount" />
                                        <Binding Path="TotalGroupCount" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>

                        <!-- File Types -->
                        <StackPanel Orientation="Horizontal" Margin="0,2,8,2" VerticalAlignment="Center">
                            <Border Width="1" Background="#D0D0D0" Margin="0,2,8,2" />
                            <TextBlock Text="Types:" FontWeight="SemiBold" FontSize="11"
                                       Foreground="#1565C0" VerticalAlignment="Center" Margin="0,0,2,0" />
                            <ToggleButton Style="{StaticResource HelpButtonStyle}"
                                          Tag="&lt;h&gt;FILTER BY FILE TYPE&lt;/h&gt;&#x0a;Show or hide duplicate groups by their file extension.&#x0a;&#x0a;&lt;b&gt;Checked&lt;/b&gt; = shown in results&#x0a;&lt;b&gt;Unchecked&lt;/b&gt; = hidden from results&#x0a;&#x0a;&lt;h&gt;Tip:&lt;/h&gt; Use this to focus on one type at a time (e.g. only images, only documents)." />
                            <Button Content="All"
                                    Command="{Binding ShowAllTypesCommand}"
                                    Padding="4,2" Margin="4,0,2,0" FontSize="10" Cursor="Hand" />
                            <Button Content="None"
                                    Command="{Binding ClearAllTypesCommand}"
                                    Padding="4,2" FontSize="10" Cursor="Hand" />
                        </StackPanel>

                        <!-- Min size + Min dups + Apply -->
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,2" VerticalAlignment="Center">
                            <Border Width="1" Background="#D0D0D0" Margin="0,2,8,2" />
                            <TextBlock Text="Min size:" FontWeight="SemiBold" FontSize="11"
                                       Foreground="#333333" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <ToggleButton Style="{StaticResource HelpButtonStyle}" Margin="0,0,4,0"
                                          Tag="&lt;h&gt;FILTER BY SIZE &amp; COUNT&lt;/h&gt;&#x0a;&#x0a;&lt;b&gt;Min file size&lt;/b&gt;&#x0a;Hide files below this threshold. Useful to skip tiny duplicates and focus on large files wasting disk space.&#x0a;&#x0a;&lt;b&gt;Min duplicates&lt;/b&gt;&#x0a;Hide groups with fewer than N copies. Default = 2. Increase to find files with many copies (e.g. 5+ scattered across folders)." />
                            <TextBox Text="{Binding MinFileSizeText, UpdateSourceTrigger=PropertyChanged}"
                                     Width="50" Padding="4,3" FontSize="11" VerticalContentAlignment="Center" />
                            <ComboBox ItemsSource="{Binding SizeUnits}"
                                      SelectedItem="{Binding SelectedSizeUnit}"
                                      Width="50" Margin="4,0,0,0" FontSize="11"
                                      VerticalContentAlignment="Center" />
                            <Border Width="1" Background="#D0D0D0" Margin="8,2" />
                            <TextBlock Text="Min dups:" FontWeight="SemiBold" FontSize="11"
                                       Foreground="#333333" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBox Text="{Binding MinDuplicateCount, UpdateSourceTrigger=PropertyChanged}"
                                     Width="35" Padding="4,3" FontSize="11" VerticalContentAlignment="Center" />
                            <Button Content="Apply" Command="{Binding ApplyFileSizeFilterCommand}"
                                    Padding="6,3" Margin="8,0,0,0" FontSize="11" Cursor="Hand" />
                        </StackPanel>
                    </WrapPanel>
                </Border>

                <!-- Row 1: Extension checkboxes (visible when filters exist) -->
                <Border Grid.Row="1" Background="#F8F9FC" CornerRadius="4" Padding="8,4" Margin="0,0,0,4"
                        BorderBrush="#E8E8E8" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ExtensionFilters.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <ItemsControl ItemsSource="{Binding ExtensionFilters}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsChecked}" Margin="0,1,12,1" Cursor="Hand">
                                    <CheckBox.Content>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Extension}" FontWeight="SemiBold"
                                                       FontSize="11" Foreground="#1565C0" />
                                            <TextBlock Text="{Binding FileCount, StringFormat=' ({0})'}"
                                                       FontSize="10" Foreground="#888888" />
                                        </StackPanel>
                                    </CheckBox.Content>
                                </CheckBox>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Row 2: Custom Rule Filter (inline — rule builder + apply/clear) -->
                <Border Grid.Row="2" Background="#FFFBF0" CornerRadius="4" Padding="8,2" Margin="0,0,0,4"
                        BorderBrush="#FFE082" BorderThickness="1">
                    <StackPanel>
                        <!-- Rule builder row -->
                        <WrapPanel Orientation="Horizontal">
                            <!-- Label -->
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,2" VerticalAlignment="Center">
                                <TextBlock Text="Custom Rules" FontSize="11" FontWeight="Bold" Foreground="#E65100"
                                           VerticalAlignment="Center" Margin="0,0,4,0" />
                                <ToggleButton Style="{StaticResource HelpButtonStyle}"
                                              Tag="&lt;h&gt;CUSTOM FILTER RULES&lt;/h&gt;&#x0a;Build rules to find or ignore files by pattern.&#x0a;&#x0a;&lt;b&gt;Action:&lt;/b&gt; Contains (check matching files) or Ignore (uncheck matching files)&#x0a;&lt;b&gt;Target:&lt;/b&gt; Filename only or full Filepath&#x0a;&lt;b&gt;Pattern:&lt;/b&gt; Text to match against&#x0a;&lt;b&gt;Regex:&lt;/b&gt; Use regular expressions&#x0a;&lt;b&gt;Ignore Case:&lt;/b&gt; Case-insensitive matching&#x0a;&#x0a;&lt;h&gt;How it works:&lt;/h&gt;&#x0a;1. Set action, target, pattern, and options&#x0a;2. Click &lt;b&gt;+ Add&lt;/b&gt; to add the rule to the list&#x0a;3. Repeat to add more rules&#x0a;4. Click &lt;b&gt;Apply Rules&lt;/b&gt; to execute all rules&#x0a;&#x0a;&lt;w&gt;Ignore ALWAYS overrides Contains.&lt;/w&gt; If a file matches both, it stays unchecked." />
                                <Border Width="1" Background="#E0D0A0" Margin="8,2" />
                            </StackPanel>

                            <!-- Rule input controls -->
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,2" VerticalAlignment="Center">
                                <ComboBox ItemsSource="{Binding FilterActions}"
                                          SelectedItem="{Binding RuleAction}"
                                          Width="70" FontSize="11" VerticalContentAlignment="Center"
                                          Margin="0,0,4,0" />
                                <TextBlock Text="on" FontSize="10" Foreground="#999999"
                                           VerticalAlignment="Center" Margin="0,0,4,0" />
                                <ComboBox ItemsSource="{Binding FilterTargets}"
                                          SelectedItem="{Binding RuleTarget}"
                                          Width="80" FontSize="11" VerticalContentAlignment="Center"
                                          Margin="0,0,4,0" />
                                <TextBlock Text="matching" FontSize="10" Foreground="#999999"
                                           VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBox Text="{Binding RulePatternText, UpdateSourceTrigger=PropertyChanged}"
                                         Width="180" Padding="4,3" FontSize="11" VerticalContentAlignment="Center"
                                         Margin="0,0,4,0"
                                         helpers:TextBoxEnterKeyBehavior.Command="{Binding AddFilterRuleCommand}">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="BorderBrush" Value="#AAAAAA" />
                                            <Setter Property="Background" Value="White" />
                                            <Setter Property="FontFamily" Value="Segoe UI" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RuleIsRegex}" Value="True">
                                                    <Setter Property="BorderBrush" Value="#42A5F5" />
                                                    <Setter Property="Background" Value="#E1F5FE" />
                                                    <Setter Property="FontFamily" Value="Consolas" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                <ToggleButton IsChecked="{Binding RuleIsRegex}"
                                              VerticalAlignment="Center" FontSize="10" Padding="6,2" Cursor="Hand"
                                              ToolTip="Use regular expression matching">
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton">
                                            <Setter Property="Content" Value=".* Regex" />
                                            <Setter Property="Foreground" Value="#555555" />
                                            <Setter Property="Background" Value="#F5F5F5" />
                                            <Setter Property="BorderBrush" Value="#CCCCCC" />
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Content" Value="✦ .* Regex" />
                                                    <Setter Property="Foreground" Value="White" />
                                                    <Setter Property="Background" Value="#1565C0" />
                                                    <Setter Property="BorderBrush" Value="#0D47A1" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#E3F2FD" />
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsChecked" Value="True" />
                                                        <Condition Property="IsMouseOver" Value="True" />
                                                    </MultiTrigger.Conditions>
                                                    <Setter Property="Background" Value="#1976D2" />
                                                </MultiTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ToggleButton.Style>
                                </ToggleButton>
                                <ToggleButton Style="{StaticResource HelpButtonStyle}" Margin="2,0,0,0"
                                              Tag="&lt;h&gt;REGEX (Regular Expression)&lt;/h&gt;&#x0a;Advanced pattern matching using special symbols.&#x0a;&#x0a;&lt;b&gt;OFF&lt;/b&gt; = plain text search (matches exact text)&#x0a;&lt;b&gt;ON&lt;/b&gt; = regex mode (matches patterns)&#x0a;&#x0a;&lt;h&gt;Common patterns:&lt;/h&gt;&#x0a;&lt;b&gt;.&lt;/b&gt; = any single character&#x0a;&lt;b&gt;*&lt;/b&gt; = repeat previous (zero or more)&#x0a;&lt;b&gt;.*&lt;/b&gt; = match anything&#x0a;&lt;b&gt;^&lt;/b&gt; = start of text&#x0a;&lt;b&gt;$&lt;/b&gt; = end of text&#x0a;&lt;b&gt;[abc]&lt;/b&gt; = any of a, b, or c&#x0a;&lt;b&gt;\d&lt;/b&gt; = any digit (0-9)&#x0a;&#x0a;&lt;h&gt;Examples:&lt;/h&gt;&#x0a;&lt;b&gt;IMG_\d+&lt;/b&gt; matches IMG_001, IMG_9999&#x0a;&lt;b&gt;^backup&lt;/b&gt; matches files starting with &quot;backup&quot;&#x0a;&lt;b&gt;\.(jpg|png)$&lt;/b&gt; matches .jpg or .png endings&#x0a;&#x0a;&lt;w&gt;Leave OFF if unsure — plain text works for most cases.&lt;/w&gt;&#x0a;&#x0a;📖 &lt;link=https://regex101.com&gt;regex101.com — test &amp; learn regex interactively&lt;/link&gt;" />
                                <ToggleButton IsChecked="{Binding RuleIgnoreCase}"
                                              VerticalAlignment="Center" FontSize="10" Padding="6,2" Margin="4,0,0,0" Cursor="Hand"
                                              ToolTip="Ignore case when matching">
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton">
                                            <Setter Property="Content" Value="Aa" />
                                            <Setter Property="Foreground" Value="#555555" />
                                            <Setter Property="Background" Value="#F5F5F5" />
                                            <Setter Property="BorderBrush" Value="#CCCCCC" />
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Content" Value="✦ Aa" />
                                                    <Setter Property="Foreground" Value="White" />
                                                    <Setter Property="Background" Value="#E65100" />
                                                    <Setter Property="BorderBrush" Value="#BF360C" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FFF3E0" />
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsChecked" Value="True" />
                                                        <Condition Property="IsMouseOver" Value="True" />
                                                    </MultiTrigger.Conditions>
                                                    <Setter Property="Background" Value="#F4511E" />
                                                </MultiTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ToggleButton.Style>
                                </ToggleButton>
                                <ToggleButton Style="{StaticResource HelpButtonStyle}" Margin="2,0,0,0"
                                              Tag="&lt;h&gt;IGNORE CASE&lt;/h&gt;&#x0a;Controls whether uppercase and lowercase letters are treated the same.&#x0a;&#x0a;&lt;b&gt;ON (default)&lt;/b&gt; = &quot;Photo&quot; matches &quot;photo&quot;, &quot;PHOTO&quot;, &quot;Photo&quot;&#x0a;&lt;b&gt;OFF&lt;/b&gt; = &quot;Photo&quot; only matches exactly &quot;Photo&quot;&#x0a;&#x0a;&lt;h&gt;When to turn OFF:&lt;/h&gt;&#x0a;When you need to distinguish between files like:&#x0a;  &lt;b&gt;README.md&lt;/b&gt; vs &lt;b&gt;readme.md&lt;/b&gt;&#x0a;  &lt;b&gt;Config.xml&lt;/b&gt; vs &lt;b&gt;config.xml&lt;/b&gt;&#x0a;&#x0a;&lt;h&gt;Tip:&lt;/h&gt; Leave ON for most cases — Windows filenames are case-insensitive anyway." />

                                <Button Content="+ Add" Command="{Binding AddFilterRuleCommand}"
                                        Padding="8,3" Margin="4,0,0,0" FontSize="11" Cursor="Hand"
                                        FontWeight="SemiBold" Foreground="#2E7D32"
                                        ToolTip="Add this rule to the list" />
                                <Border Width="1" Background="#E0D0A0" Margin="8,2" />
                            </StackPanel>

                            <!-- All / None | Apply -->
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,2" VerticalAlignment="Center">
                                <Button Content="✓ All" Command="{Binding EnableAllRulesCommand}"
                                        Padding="6,3" FontSize="11" Cursor="Hand"
                                        Foreground="#2E7D32"
                                        ToolTip="Enable all rules" />
                                <Button Content="✕ None" Command="{Binding DisableAllRulesCommand}"
                                        Padding="6,3" Margin="4,0,0,0" FontSize="11" Cursor="Hand"
                                        Foreground="#888888"
                                        ToolTip="Disable all rules" />
                                <Border Width="1" Background="#E0D0A0" Margin="8,2" />
                                <Button Content="▶ Apply" Command="{Binding ApplyFilterRulesCommand}"
                                        Padding="6,3" FontSize="11" Cursor="Hand"
                                        FontWeight="SemiBold" Foreground="#1565C0"
                                        ToolTip="Apply all enabled rules" />
                            </StackPanel>
                        </WrapPanel>

                        <!-- Rules list (horizontal chips) — only visible when rules exist -->
                        <ItemsControl ItemsSource="{Binding FilterRules}" Margin="0,4,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,6,4" Padding="6,3" CornerRadius="4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E3F2FD" />
                                                <Setter Property="BorderBrush" Value="#42A5F5" />
                                                <Setter Property="BorderThickness" Value="1" />
                                                <Setter Property="Opacity" Value="1" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Action}" Value="Exclude">
                                                        <Setter Property="Background" Value="#E1F5FE" />
                                                        <Setter Property="BorderBrush" Value="#29B6F6" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                        <Setter Property="Background" Value="#EEEEEE" />
                                                        <Setter Property="BorderBrush" Value="#D0D0D0" />
                                                        <Setter Property="Opacity" Value="0.6" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <!-- Enable/disable checkbox -->
                                            <CheckBox IsChecked="{Binding IsEnabled}" VerticalAlignment="Center"
                                                      Margin="0,0,4,0" Cursor="Hand"
                                                      ToolTip="Enable or disable this rule temporarily" />
                                            <!-- Priority number -->
                                            <Border CornerRadius="3" Padding="5,1" Margin="0,0,4,0"
                                                    VerticalAlignment="Center" Width="20">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#424242" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                <Setter Property="Background" Value="#BDBDBD" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Priority}" FontSize="9" FontWeight="Bold"
                                                           Foreground="White" HorizontalAlignment="Center" />
                                            </Border>
                                            <!-- Move up/down -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,4,0" VerticalAlignment="Center">
                                                <Button Command="{Binding DataContext.MoveFilterRuleUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" Cursor="Hand" ToolTip="Move up (higher priority)">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="UpBorder" Background="#E0E0E0" CornerRadius="2,0,0,2"
                                                                    Padding="3,1" BorderThickness="0">
                                                                <TextBlock Text="▲" FontSize="8" Foreground="#555555"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="UpBorder" Property="Background" Value="#1565C0" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <Button Command="{Binding DataContext.MoveFilterRuleDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" Cursor="Hand" ToolTip="Move down (lower priority)">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="DownBorder" Background="#E0E0E0" CornerRadius="0,2,2,0"
                                                                    Padding="3,1" BorderThickness="0">
                                                                <TextBlock Text="▼" FontSize="8" Foreground="#555555"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="DownBorder" Property="Background" Value="#1565C0" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                            <!-- Action dropdown -->
                                            <ComboBox ItemsSource="{Binding DataContext.FilterActions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      SelectedItem="{Binding Action}"
                                                      FontSize="9" Width="70" VerticalContentAlignment="Center"
                                                      Margin="0,0,4,0" />
                                            <!-- Target dropdown -->
                                            <ComboBox ItemsSource="{Binding DataContext.FilterTargets, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      SelectedItem="{Binding Target}"
                                                      FontSize="9" Width="72" VerticalContentAlignment="Center"
                                                      Margin="0,0,4,0" />
                                            <!-- Editable pattern text -->
                                            <TextBox Text="{Binding Pattern, UpdateSourceTrigger=LostFocus}"
                                                     MinWidth="80" MaxWidth="200" Padding="4,2" FontSize="11"
                                                     FontWeight="SemiBold" VerticalContentAlignment="Center"
                                                     BorderThickness="0,0,0,1.5" BorderBrush="#42A5F5"
                                                     Background="Transparent" Margin="0,0,2,0"
                                                     ToolTip="Click to edit pattern" />
                                            <!-- Regex toggle button (same style as toolbar) -->
                                            <ToggleButton IsChecked="{Binding IsRegex}"
                                                          VerticalAlignment="Center" FontSize="9" Padding="4,1" Margin="4,0,0,0" Cursor="Hand"
                                                          ToolTip="Toggle regex matching">
                                                <ToggleButton.Style>
                                                    <Style TargetType="ToggleButton">
                                                        <Setter Property="Content" Value=".*" />
                                                        <Setter Property="Foreground" Value="#999999" />
                                                        <Setter Property="Background" Value="#F0F0F0" />
                                                        <Setter Property="BorderBrush" Value="#D0D0D0" />
                                                        <Setter Property="BorderThickness" Value="1" />
                                                        <Setter Property="FontFamily" Value="Consolas" />
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border Background="{TemplateBinding Background}"
                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                                            CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter Property="Content" Value="✦ .*" />
                                                                <Setter Property="Foreground" Value="White" />
                                                                <Setter Property="Background" Value="#1565C0" />
                                                                <Setter Property="BorderBrush" Value="#0D47A1" />
                                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#E3F2FD" />
                                                            </Trigger>
                                                            <MultiTrigger>
                                                                <MultiTrigger.Conditions>
                                                                    <Condition Property="IsChecked" Value="True" />
                                                                    <Condition Property="IsMouseOver" Value="True" />
                                                                </MultiTrigger.Conditions>
                                                                <Setter Property="Background" Value="#1976D2" />
                                                            </MultiTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ToggleButton.Style>
                                            </ToggleButton>
                                            <!-- IgnoreCase toggle button (same style as toolbar) -->
                                            <ToggleButton IsChecked="{Binding IgnoreCase}"
                                                          VerticalAlignment="Center" FontSize="9" Padding="4,1" Margin="2,0,4,0" Cursor="Hand"
                                                          ToolTip="Toggle case-insensitive matching">
                                                <ToggleButton.Style>
                                                    <Style TargetType="ToggleButton">
                                                        <Setter Property="Content" Value="Aa" />
                                                        <Setter Property="Foreground" Value="#999999" />
                                                        <Setter Property="Background" Value="#F0F0F0" />
                                                        <Setter Property="BorderBrush" Value="#D0D0D0" />
                                                        <Setter Property="BorderThickness" Value="1" />
                                                        <Setter Property="FontFamily" Value="Consolas" />
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border Background="{TemplateBinding Background}"
                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                                            CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter Property="Content" Value="✦ Aa" />
                                                                <Setter Property="Foreground" Value="White" />
                                                                <Setter Property="Background" Value="#E65100" />
                                                                <Setter Property="BorderBrush" Value="#BF360C" />
                                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#FFF3E0" />
                                                            </Trigger>
                                                            <MultiTrigger>
                                                                <MultiTrigger.Conditions>
                                                                    <Condition Property="IsChecked" Value="True" />
                                                                    <Condition Property="IsMouseOver" Value="True" />
                                                                </MultiTrigger.Conditions>
                                                                <Setter Property="Background" Value="#F4511E" />
                                                            </MultiTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ToggleButton.Style>
                                            </ToggleButton>
                                            <!-- Remove button -->
                                            <Button Command="{Binding DataContext.RemoveFilterRuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Cursor="Hand" VerticalAlignment="Center" Margin="2,0,0,0"
                                                    ToolTip="Remove this rule">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="RemoveBorder" Width="16" Height="16" CornerRadius="8"
                                                                Background="#E0E0E0" BorderThickness="0">
                                                            <TextBlock x:Name="RemoveText" Text="✕" FontSize="9" FontWeight="Bold"
                                                                       Foreground="#757575"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       Margin="0,-1,0,0" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="RemoveBorder" Property="Background" Value="#EF5350" />
                                                                <Setter TargetName="RemoveText" Property="Foreground" Value="White" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Action Section (inline) -->
                <Border Grid.Row="3" Background="#FFF3E0" CornerRadius="4" Padding="8,2" Margin="0,0,0,4">
                    <WrapPanel Orientation="Horizontal">
                        <!-- Label + count -->
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,2" VerticalAlignment="Center">
                            <TextBlock Text="Action" FontSize="11" FontWeight="Bold" Foreground="#E65100"
                                       VerticalAlignment="Center" Margin="0,0,4,0" />
                            <ToggleButton Style="{StaticResource HelpButtonStyle}"
                                          Tag="&lt;h&gt;TAKE ACTION on selected files&lt;/h&gt;&#x0a;&#x0a;&lt;b&gt;Delete&lt;/b&gt;&#x0a;Permanently removes checked files from disk.&#x0a;&lt;w&gt;No Recycle Bin &#x2014; cannot be undone.&lt;/w&gt;&#x0a;&#x0a;&lt;b&gt;Move&lt;/b&gt;&#x0a;Relocates checked files to the target folder.&#x0a;Filenames are preserved. Original files are removed.&#x0a;&#x0a;&lt;w&gt;Both actions affect ALL checked files across ALL groups.&lt;/w&gt; Double-check your selection before proceeding." />
                            <TextBlock FontSize="10" Foreground="#555555" Margin="8,0,0,0"
                                       VerticalAlignment="Center">
                                <TextBlock.Text>
                                    <Binding Path="SelectedFileCount" StringFormat="{}{0} files selected" />
                                </TextBlock.Text>
                            </TextBlock>
                            <Border Width="1" Background="#E0D0A0" Margin="8,2" />
                        </StackPanel>

                        <!-- Quick Select buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,2" VerticalAlignment="Center">
                            <Button Content="✓ All" Command="{Binding SelectAllFilesCommand}"
                                    Padding="6,3" Margin="0,0,4,0" FontSize="11" Cursor="Hand"
                                    ToolTip="Select all files in all groups" />
                            <Button Content="✓ Newer" Command="{Binding SelectNewerFilesCommand}"
                                    Padding="6,3" Margin="0,0,4,0" FontSize="11" Cursor="Hand"
                                    ToolTip="Select newer duplicates (keep oldest unselected)" />
                            <Button Content="✓ Older" Command="{Binding SelectOlderFilesCommand}"
                                    Padding="6,3" Margin="0,0,4,0" FontSize="11" Cursor="Hand"
                                    ToolTip="Select older duplicates (keep newest unselected)" />
                            <Button Content="✕ Clear" Command="{Binding ClearFileSelectionCommand}"
                                    Padding="6,3" FontSize="11" Cursor="Hand"
                                    Foreground="#888888"
                                    ToolTip="Clear all file selections" />
                            <Border Width="1" Background="#E0D0A0" Margin="8,2" />
                        </StackPanel>

                        <!-- Delete / Move -->
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,2" VerticalAlignment="Center">
                            <Button Content="🗑 Delete" Command="{Binding DeleteSelectedFilesCommand}"
                                    Padding="6,3" Margin="0,0,0,0" FontSize="11" Cursor="Hand"
                                    Foreground="#C62828"
                                    ToolTip="Send selected files to Recycle Bin" />
                            <Button Content="↶" Command="{Binding UndoLastActionCommand}"
                                    ToolTip="{Binding UndoTooltip}"
                                    Padding="6,3" Margin="4,0,0,0" FontSize="13" Cursor="Hand"
                                    FontWeight="Bold" Foreground="#388E3C" />
                            <Border Width="1" Background="#E0D0A0" Margin="8,2" />
                            <TextBlock Text="Move to:" FontSize="11" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Foreground="#E65100" Margin="0,0,4,0" />
                            <TextBox Text="{Binding MoveTargetPath, UpdateSourceTrigger=PropertyChanged}"
                                     Width="200" Padding="4,3" FontSize="11" VerticalContentAlignment="Center" />
                            <Button Content="..." Command="{Binding BrowseMoveTargetCommand}"
                                    Padding="6,3" Margin="4,0,4,0" FontSize="11" Cursor="Hand"
                                    ToolTip="Browse for target folder" />
                            <Button Content="📁 Move" Command="{Binding MoveSelectedFilesCommand}"
                                    Padding="6,3" FontSize="11" Cursor="Hand"
                                    Foreground="#1565C0"
                                    ToolTip="Move all selected files to the target folder" />
                        </StackPanel>
                    </WrapPanel>
                </Border>

                <GroupBox Grid.Row="4" Header="Duplicate Groups" Padding="4">
                <ListView x:Name="DuplicateGroupsList"
                          ItemsSource="{Binding FilteredDuplicateGroups}"
                          SelectedItem="{Binding SelectedDuplicateGroup}"
                          SelectionMode="Extended"
                          SelectionChanged="DuplicateGroups_SelectionChanged"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          VirtualizingPanel.ScrollUnit="Pixel"
                          ScrollViewer.CanContentScroll="True">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#DDDDDD" BorderThickness="0,0,0,1"
                                    Padding="4,8" Margin="0,0,0,4">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="{Binding Count, StringFormat='{}{0} files'}" />
                                        <TextBlock Text=" — " Foreground="Gray" />
                                        <TextBlock Text="{Binding FormattedFileSize}" Foreground="#1565C0" />
                                        <TextBlock Text=" each — " Foreground="Gray" />
                                        <TextBlock Text="{Binding FormattedWastedSize, StringFormat='wasted: {0}'}"
                                                   Foreground="#C62828" FontWeight="SemiBold" />
                                        <Button Content="✓ Select All"
                                                Command="{Binding DataContext.SelectAllInGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Padding="6,2" Margin="12,0,4,0"
                                                FontSize="11" Cursor="Hand"
                                                Foreground="#2E7D32" />
                                        <Button Content="✕ Clear"
                                                Command="{Binding DataContext.ClearSelectionInGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Padding="6,2" Margin="0,0,4,0"
                                                FontSize="11" Cursor="Hand"
                                                Foreground="#888888" />
                                        <Button Content="{Binding DeleteAllLabel}"
                                                Command="{Binding DataContext.DeleteAllInGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Padding="6,2" Margin="4,0,0,0"
                                                FontSize="11" Cursor="Hand"
                                                Foreground="#C62828" FontWeight="SemiBold" />
                                    </StackPanel>

                                    <!-- Mini Inline Preview -->
                                    <Border Margin="16,2,0,6" Padding="6" CornerRadius="4"
                                            Background="#F5F7FA" BorderBrush="#E8E8E8" BorderThickness="1"
                                            HorizontalAlignment="Left"
                                            Visibility="{Binding DataContext.IsMiniPreview, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}">
                                        <StackPanel Orientation="Horizontal">
                                            <!-- Image thumbnail -->
                                            <Image x:Name="ThumbImg"
                                                   Source="{Binding FirstFilePath, Converter={StaticResource MiniPreview}}"
                                                   Width="60" Height="60" Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="LowQuality"
                                                   Margin="0,0,8,0">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <Trigger Property="Source" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                            <!-- File type icon (only when no thumbnail) -->
                                            <TextBlock Text="{Binding FirstFilePath, Converter={StaticResource FileTypeIcon}}"
                                                       FontSize="32" VerticalAlignment="Center" Margin="0,0,8,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Source, ElementName=ThumbImg}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FirstFileName}" FontSize="11" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="300" />
                                                <TextBlock Text="{Binding FileExtension}" FontSize="10" Foreground="#1565C0" />
                                                <TextBlock Text="{Binding FormattedFileSize}" FontSize="10" Foreground="#888888" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <ItemsControl ItemsSource="{Binding Files}" Margin="16,0,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                                    <CheckBox IsChecked="{Binding IsFileSelected}"
                                                              VerticalAlignment="Center" Margin="0,0,4,0" />
                                                    <Button Content="📂 Open"
                                                            Command="{Binding DataContext.OpenFileLocationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding FilePath}"
                                                            Padding="6,2" Margin="0,0,4,0"
                                                            FontSize="11" Cursor="Hand" />
                                                    <Button Content="🗑 Delete"
                                                            Command="{Binding DataContext.DeleteFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="6,2" Margin="0,0,8,0"
                                                            FontSize="11" Cursor="Hand"
                                                            Foreground="#C62828" />
                                                    <TextBlock Text="{Binding FilePath}"
                                                               Foreground="#333333" FontSize="12"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding FilePath}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </GroupBox>
            </Grid>

            <!-- Row 2: Status Bar + Resource Monitor -->
            <Border Grid.Row="2" Background="#F5F5F5" Padding="8,4" Margin="0,8,0,0"
                    CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Foreground="#666666" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="{Binding ResourceMemory}" Foreground="#1565C0" FontSize="11" Margin="0,0,12,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ResourceCpu}" Foreground="#E65100" FontSize="11" Margin="0,0,12,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ResourceThreads}" Foreground="#666666" FontSize="11" VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

    </Grid>
            </TabItem>

        </TabControl>
        </Grid>

        <!-- Column 1: Analytics Dashboard (full window height, toggleable) -->
        <Border Grid.Column="1" Background="#FAFAFA" CornerRadius="6"
                BorderBrush="#E0E0E0" BorderThickness="1" Padding="12" Margin="4,4,4,4"
                Width="320"
                Visibility="{Binding IsAnalyticsVisible, Converter={StaticResource BoolToVisibility}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel DataContext="{Binding Analytics}">

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Analytics" FontSize="16" FontWeight="Bold"
                                   Foreground="#1A237E" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="✕ Close" Padding="8,4"
                                FontSize="11" Cursor="Hand" Foreground="#666666"
                                Click="CloseAnalytics_Click" />
                    </Grid>

                    <!-- Summary Cards -->
                    <Border Background="White" CornerRadius="4" Padding="10" Margin="0,0,0,8"
                            BorderBrush="#E0E0E0" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                                <TextBlock Text="Total Files" Foreground="#999999" FontSize="10" />
                                <TextBlock Text="{Binding TotalFiles, StringFormat=N0}" FontSize="20" FontWeight="Bold" Foreground="#333333" />
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                                <TextBlock Text="Duplicates" Foreground="#999999" FontSize="10" />
                                <TextBlock Text="{Binding TotalDuplicates, StringFormat=N0}" FontSize="20" FontWeight="Bold" Foreground="#C62828" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,8">
                                <TextBlock Text="Groups" Foreground="#999999" FontSize="10" />
                                <TextBlock Text="{Binding DuplicateGroups, StringFormat=N0}" FontSize="20" FontWeight="Bold" Foreground="#1565C0" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                                <TextBlock Text="Scan Time" Foreground="#999999" FontSize="10" />
                                <TextBlock Text="{Binding Duration, StringFormat='{}{0:mm\\:ss\\.f}'}" FontSize="20" FontWeight="Bold" Foreground="#333333" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Text="Wasted Space" Foreground="#999999" FontSize="10" />
                                <TextBlock Text="{Binding FormattedWastedSize}" FontSize="20" FontWeight="Bold" Foreground="#C62828" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1">
                                <TextBlock Text="Duplicate %" Foreground="#999999" FontSize="10" />
                                <TextBlock Text="{Binding DuplicatePercentage, StringFormat='{}{0:F1}%'}" FontSize="20" FontWeight="Bold" Foreground="#E65100" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Wasted Space Bar -->
                    <Border Background="White" CornerRadius="4" Padding="10" Margin="0,0,0,8"
                            BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Wasted vs Total" FontWeight="SemiBold" FontSize="11"
                                       Foreground="#555555" Margin="0,0,0,6" />
                            <Grid Height="20">
                                <Border Background="#E8F5E9" CornerRadius="3" />
                                <Border Background="#EF9A9A" CornerRadius="3"
                                        HorizontalAlignment="Left">
                                    <Border.Width>
                                        <MultiBinding Converter="{x:Static helpers:PercentToWidthConverter.Instance}">
                                            <Binding Path="WastedPercentage" />
                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" />
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Border Width="10" Height="10" Background="#EF9A9A" CornerRadius="2" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding FormattedWastedSize, StringFormat='Wasted: {0}'}" FontSize="10" Foreground="#666666" Margin="0,0,12,0" />
                                <Border Width="10" Height="10" Background="#E8F5E9" CornerRadius="2" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding FormattedTotalSize, StringFormat='Total: {0}'}" FontSize="10" Foreground="#666666" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Top Extensions -->
                    <Border Background="White" CornerRadius="4" Padding="10" Margin="0,0,0,8"
                            BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Top Duplicate Types" FontWeight="SemiBold" FontSize="11"
                                       Foreground="#555555" Margin="0,0,0,6" />
                            <ItemsControl ItemsSource="{Binding TopExtensions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#E3F2FD" CornerRadius="3"
                                                    Padding="4,2" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Extension}" FontSize="10"
                                                           FontWeight="SemiBold" Foreground="#1565C0" />
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding FileCount, StringFormat='{}{0} files'}"
                                                       FontSize="10" Foreground="#888888" Margin="8,0,0,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding FormattedSize}"
                                                       FontSize="10" Foreground="#666666"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Size Distribution -->
                    <Border Background="White" CornerRadius="4" Padding="10"
                            BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Size Distribution" FontWeight="SemiBold" FontSize="11"
                                       Foreground="#555555" Margin="0,0,0,6" />
                            <ItemsControl ItemsSource="{Binding SizeDistribution}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                <TextBlock Text="{Binding Label}" FontSize="10" Foreground="#666666" />
                                                <TextBlock Text="{Binding FileCount, StringFormat=' ({0})'}" FontSize="10" Foreground="#999999" />
                                            </StackPanel>
                                            <Grid Grid.Row="1" Height="8" Margin="0,2,0,0">
                                                <Border Background="#EEEEEE" CornerRadius="2" />
                                                <Border Background="#7986CB" CornerRadius="2"
                                                        HorizontalAlignment="Left">
                                                    <Border.Width>
                                                        <MultiBinding Converter="{x:Static helpers:PercentToWidthConverter.Instance}">
                                                            <Binding Path="BarWidth" />
                                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" />
                                                        </MultiBinding>
                                                    </Border.Width>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Column 1: Folder Action Panel (shown when Folder Control tab is active) -->
        <Border Grid.Column="1" Background="#FAFAFA" CornerRadius="6"
                BorderBrush="#E0E0E0" BorderThickness="1" Padding="12" Margin="4,4,4,4"
                Width="640"
                Visibility="{Binding IsFolderControlActive, Converter={StaticResource BoolToVisibility}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <!-- Header -->
                    <TextBlock Text="Folder Action" FontSize="16" FontWeight="Bold"
                               Foreground="#E65100" Margin="0,0,0,12" />

                    <!-- Selection summary -->
                    <Border Background="White" CornerRadius="4" Padding="10" Margin="0,0,0,8"
                            BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Selection" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#333333" Margin="0,0,0,6" />
                            <TextBlock FontSize="24" FontWeight="Bold" Foreground="#E65100" Margin="0,0,0,4">
                                <TextBlock.Text>
                                    <Binding Path="SelectedFolderCount" StringFormat="{}{0}" />
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock Text="folders selected" FontSize="11" Foreground="#888888" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal">
                                <Button Content="✓ All" Command="{Binding SelectAllFoldersCommand}"
                                        Padding="8,4" Margin="0,0,6,0" FontSize="11" Cursor="Hand" />
                                <Button Content="✕ Clear" Command="{Binding ClearFolderSelectionCommand}"
                                        Padding="8,4" FontSize="11" Cursor="Hand" Foreground="#888888" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Flatten Folders -->
                    <Border Background="White" CornerRadius="4" Padding="10" Margin="0,0,0,8"
                            BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Flatten Folders" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#C62828" Margin="0,0,0,4" />
                            <TextBlock Text="Move every file from subdirectories up to the root of each selected folder. Empty subdirectories are removed. Name conflicts get (2), (3)."
                                       FontSize="10" Foreground="#888888" TextWrapping="Wrap" Margin="0,0,0,8" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="📦 Move Files to Root"
                                        Command="{Binding FlattenSelectedFoldersCommand}"
                                        Padding="10,6" FontSize="11" Cursor="Hand"
                                        Foreground="#C62828" FontWeight="SemiBold"
                                        HorizontalAlignment="Stretch"
                                        ToolTip="Move every file from subdirectories up to the root of each selected folder" />
                                <Button Grid.Column="1" Content="↶" Command="{Binding UndoLastActionCommand}"
                                        ToolTip="{Binding UndoTooltip}"
                                        Padding="6,3" Margin="4,0,0,0" FontSize="13" Cursor="Hand"
                                        FontWeight="Bold" Foreground="#388E3C" />
                                <ToggleButton Grid.Column="2" Style="{StaticResource HelpButtonStyle}"
                                              Margin="6,0,0,0"
                                              Tag="&lt;h&gt;MOVE FILES TO ROOT&lt;/h&gt;&#x0a;Flattens every selected folder — moves all files from nested subdirectories up to the folder's own root.&#x0a;&#x0a;&lt;b&gt;Example:&lt;/b&gt;&#x0a;Before:&#x0a;  Photos\2024\Jan\a.jpg&#x0a;  Photos\2024\Feb\b.jpg&#x0a;  Photos\2024\Feb\sub\c.jpg&#x0a;&#x0a;After:&#x0a;  Photos\2024\a.jpg&#x0a;  Photos\2024\b.jpg&#x0a;  Photos\2024\c.jpg&#x0a;&#x0a;&lt;b&gt;What it does:&lt;/b&gt;&#x0a;• Recursively walks every selected folder&#x0a;• Moves each file (regardless of depth) to the root&#x0a;• Appends (2), (3) to resolve name conflicts&#x0a;• Deletes empty subdirectories afterward&#x0a;&#x0a;&lt;b&gt;Safety:&lt;/b&gt;&#x0a;• Confirmation dialog shows affected file count&#x0a;• Skips files that are locked or access-denied&#x0a;&#x0a;&lt;h&gt;Undo (↶) reverses the last action.&lt;/h&gt;" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Scan Action -->
                    <Border Background="White" CornerRadius="4" Padding="10" Margin="0,0,0,8"
                            BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Scan Action" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#C62828" Margin="0,0,0,4" />
                            <TextBlock Text="Click Scan Folders to discover subfolder names and file types inside selected result folders. Select items and clear them."
                                       FontSize="10" Foreground="#888888" TextWrapping="Wrap" Margin="0,0,0,8" />

                            <!-- Include subdirectories toggle -->
                            <CheckBox IsChecked="{Binding FolderSearchIncludeSubdirectories}"
                                      Content="Include Subdirectories" FontSize="11"
                                      Cursor="Hand" Margin="0,0,0,6"
                                      ToolTip="When checked, scan recursively into nested subfolders. When unchecked, only scan immediate children." />

                            <!-- Scan button + help -->
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Command="{Binding ScanSubfoldersCommand}"
                                        Padding="10,6" FontSize="11" Cursor="Hand"
                                        FontWeight="SemiBold" Foreground="#1565C0"
                                        HorizontalAlignment="Stretch"
                                        ToolTip="Discover subfolders and file types inside the selected result folders">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Content" Value="🔍 Scan Folders" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsScanningFolders}" Value="True">
                                                    <Setter Property="Content" Value="⏳ Scanning…" />
                                                    <Setter Property="Foreground" Value="#999999" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <ToggleButton Grid.Column="1" Style="{StaticResource HelpButtonStyle}"
                                              Margin="6,0,0,0"
                                              Tag="&lt;h&gt;SCAN FOLDERS&lt;/h&gt;&#x0a;Inspects the folders you &lt;b&gt;checked&lt;/b&gt; in the Folder Search results and builds two inventories:&#x0a;&#x0a;&lt;b&gt;Subfolders&lt;/b&gt; — unique subfolder names, ranked by how many result folders contain them.&#x0a;Example: &lt;b&gt;node_modules (in 14 folders)&lt;/b&gt;&#x0a;&#x0a;&lt;b&gt;File Types&lt;/b&gt; — unique file extensions, ranked by total file count.&#x0a;Example: &lt;b&gt;.log (237 files)&lt;/b&gt;&#x0a;&#x0a;&lt;b&gt;Scope:&lt;/b&gt;&#x0a;• &lt;b&gt;Include Subdirectories&lt;/b&gt; off — only immediate children of each selected folder&#x0a;• &lt;b&gt;Include Subdirectories&lt;/b&gt; on — recurses through every nested level&#x0a;&#x0a;&lt;b&gt;Expand any item&lt;/b&gt; to see the exact paths it was found in.&#x0a;&#x0a;&lt;h&gt;Next:&lt;/h&gt; Check items then click &lt;b&gt;Clear Selected Subfolders&lt;/b&gt; or &lt;b&gt;Clear Selected Files&lt;/b&gt; to delete them." />
                            </Grid>

                            <!-- Scan progress bar -->
                            <ProgressBar Height="4" Margin="0,0,0,4"
                                         IsIndeterminate="{Binding IsScanningFolders}"
                                         Visibility="{Binding IsScanningFolders, Converter={StaticResource BoolToVisibility}}"
                                         Foreground="#1565C0" Background="#E3F2FD"
                                         BorderThickness="0" />

                            <!-- Scan status -->
                            <TextBlock FontSize="10" TextWrapping="Wrap" Margin="0,0,0,8">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#666666" />
                                        <Setter Property="Text" Value="{Binding ClearSubfolderStatus}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsScanningFolders}" Value="True">
                                                <Setter Property="Foreground" Value="#1565C0" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- ── Subfolders section ── -->
                            <TextBlock Text="Subfolders" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#1565C0" Margin="0,0,0,4" />

                            <!-- Filter input -->
                            <Grid Margin="0,0,0,6">
                                <TextBox Text="{Binding SubfolderFilter, UpdateSourceTrigger=PropertyChanged}"
                                         x:Name="SubfolderFilterBox"
                                         Padding="6,4" FontSize="11"
                                         VerticalContentAlignment="Center" />
                                <TextBlock Text="🔍 Filter subfolder names..."
                                           Padding="8,5" FontSize="11" Foreground="#AAAAAA"
                                           VerticalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=SubfolderFilterBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                            <!-- Select All / Clear buttons for subfolders -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Button Content="✓ All" Command="{Binding SelectAllSubfoldersCommand}"
                                        Padding="8,3" Margin="0,0,6,0" FontSize="10" Cursor="Hand" />
                                <Button Content="✕ None" Command="{Binding ClearSubfolderSelectionCommand}"
                                        Padding="8,3" FontSize="10" Cursor="Hand" Foreground="#888888" />
                            </StackPanel>

                            <!-- Subfolder list with expandable details (virtualized, pixel-scroll) -->
                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="3" MaxHeight="280">
                                <ItemsControl ItemsSource="{Binding FilteredSubfolders}"
                                              ScrollViewer.CanContentScroll="True"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              VirtualizingPanel.IsVirtualizing="True"
                                              VirtualizingPanel.VirtualizationMode="Recycling"
                                              VirtualizingPanel.ScrollUnit="Pixel">
                                    <ItemsControl.Template>
                                        <ControlTemplate TargetType="ItemsControl">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto" Focusable="False" CanContentScroll="True">
                                                <ItemsPresenter />
                                            </ScrollViewer>
                                        </ControlTemplate>
                                    </ItemsControl.Template>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="4,2" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                                                <Expander IsExpanded="False">
                                                    <Expander.Header>
                                                        <StackPanel Orientation="Horizontal">
                                                            <CheckBox IsChecked="{Binding IsSelected}" Cursor="Hand"
                                                                      VerticalAlignment="Center" Margin="0,0,6,0" />
                                                            <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                                                                       Foreground="#333333" VerticalAlignment="Center" />
                                                            <TextBlock FontSize="10" Foreground="#888888"
                                                                       VerticalAlignment="Center" Margin="6,0,0,0">
                                                                <TextBlock.Text>
                                                                    <Binding Path="Count" StringFormat="in {0} folders" />
                                                                </TextBlock.Text>
                                                            </TextBlock>
                                                            <TextBlock Text="·" FontSize="10" Foreground="#CCCCCC"
                                                                       VerticalAlignment="Center" Margin="6,0,0,0" />
                                                            <TextBlock Text="{Binding TotalSizeDisplay}" FontSize="10"
                                                                       Foreground="#1565C0" FontWeight="SemiBold"
                                                                       VerticalAlignment="Center" Margin="6,0,0,0" />
                                                        </StackPanel>
                                                    </Expander.Header>
                                                    <!-- Expanded: filter + paged parent locations -->
                                                    <StackPanel Margin="24,4,0,6">
                                                        <TextBox Text="{Binding LocationFilter, UpdateSourceTrigger=PropertyChanged, Delay=250}"
                                                                 FontSize="10" Padding="4,3" Margin="0,0,0,4"
                                                                 ToolTip="Filter locations (case-insensitive)" />
                                                        <ItemsControl ItemsSource="{Binding PagedLocations}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock FontSize="10" Foreground="#666666"
                                                                               TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                                                               Margin="0,1" ToolTip="{Binding FullPath}">
                                                                        <Run Text="📁" /><Run Text=" " /><Run Text="{Binding ParentPath, Mode=OneWay}" />
                                                                    </TextBlock>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                            <Button Content="‹ Prev" Click="SubfolderPrevPage_Click"
                                                                    IsEnabled="{Binding CanGoPrevPage}"
                                                                    Padding="6,2" FontSize="10" Cursor="Hand" />
                                                            <Button Content="Next ›" Click="SubfolderNextPage_Click"
                                                                    IsEnabled="{Binding CanGoNextPage}"
                                                                    Padding="6,2" Margin="4,0,0,0" FontSize="10" Cursor="Hand" />
                                                            <TextBlock Text="{Binding PageStatus}" FontSize="10"
                                                                       Foreground="#888888" VerticalAlignment="Center"
                                                                       Margin="10,0,0,0" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Expander>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>

                            <!-- Clear subfolders button + undo + help -->
                            <Grid Margin="0,6,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="🗑 Clear Selected Subfolders"
                                        Command="{Binding ClearSelectedSubfoldersCommand}"
                                        Padding="10,6" FontSize="11" Cursor="Hand"
                                        Foreground="#C62828" FontWeight="SemiBold"
                                        HorizontalAlignment="Stretch"
                                        ToolTip="Delete checked subfolders from all selected result folders" />
                                <Button Grid.Column="1" Content="↶" Command="{Binding UndoLastActionCommand}"
                                        ToolTip="{Binding UndoTooltip}"
                                        Padding="6,3" Margin="4,0,0,0" FontSize="13" Cursor="Hand"
                                        FontWeight="Bold" Foreground="#388E3C" />
                                <ToggleButton Grid.Column="2" Style="{StaticResource HelpButtonStyle}"
                                              Margin="6,0,0,0"
                                              Tag="&lt;h&gt;CLEAR SELECTED SUBFOLDERS&lt;/h&gt;&#x0a;Sends every checked subfolder to the Recycle Bin from inside each selected result folder.&#x0a;&#x0a;&lt;b&gt;What it removes:&lt;/b&gt;&#x0a;• The subfolder itself and all its contents (files and nested subfolders)&#x0a;&#x0a;&lt;b&gt;Common uses:&lt;/b&gt;&#x0a;• Clean &lt;b&gt;node_modules&lt;/b&gt; from many projects at once&#x0a;• Wipe &lt;b&gt;bin&lt;/b&gt;, &lt;b&gt;obj&lt;/b&gt;, &lt;b&gt;.vs&lt;/b&gt; from .NET solutions&#x0a;• Remove &lt;b&gt;__pycache__&lt;/b&gt; across Python repos&#x0a;&#x0a;&lt;b&gt;Safety:&lt;/b&gt;&#x0a;• Confirmation dialog shows affected folder count&#x0a;• Skips subfolders that are locked or access-denied&#x0a;&#x0a;&lt;h&gt;Sent to Recycle Bin — restorable from there.&lt;/h&gt;" />
                            </Grid>

                            <!-- ── File Types section ── -->
                            <TextBlock Text="File Types" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#1565C0" Margin="0,0,0,4" />

                            <!-- File type filter -->
                            <Grid Margin="0,0,0,6">
                                <TextBox Text="{Binding FileTypeFilter, UpdateSourceTrigger=PropertyChanged}"
                                         x:Name="FileTypeFilterBox"
                                         Padding="6,4" FontSize="11"
                                         VerticalContentAlignment="Center" />
                                <TextBlock Text="🔍 Filter extensions (e.g. .log)..."
                                           Padding="8,5" FontSize="11" Foreground="#AAAAAA"
                                           VerticalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=FileTypeFilterBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                            <!-- Select All / Clear buttons for file types -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Button Content="✓ All" Command="{Binding SelectAllFileTypesCommand}"
                                        Padding="8,3" Margin="0,0,6,0" FontSize="10" Cursor="Hand" />
                                <Button Content="✕ None" Command="{Binding ClearFileTypeSelectionCommand}"
                                        Padding="8,3" FontSize="10" Cursor="Hand" Foreground="#888888" />
                            </StackPanel>

                            <!-- File types list with expandable details (virtualized, pixel-scroll) -->
                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="3" MaxHeight="280">
                                <ItemsControl ItemsSource="{Binding FilteredFileTypes}"
                                              ScrollViewer.CanContentScroll="True"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              VirtualizingPanel.IsVirtualizing="True"
                                              VirtualizingPanel.VirtualizationMode="Recycling"
                                              VirtualizingPanel.ScrollUnit="Pixel">
                                    <ItemsControl.Template>
                                        <ControlTemplate TargetType="ItemsControl">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto" Focusable="False" CanContentScroll="True">
                                                <ItemsPresenter />
                                            </ScrollViewer>
                                        </ControlTemplate>
                                    </ItemsControl.Template>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="4,2" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                                                <Expander IsExpanded="False">
                                                    <Expander.Header>
                                                        <StackPanel Orientation="Horizontal">
                                                            <CheckBox IsChecked="{Binding IsSelected}" Cursor="Hand"
                                                                      VerticalAlignment="Center" Margin="0,0,6,0" />
                                                            <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                                                                       Foreground="#333333" VerticalAlignment="Center" />
                                                            <TextBlock FontSize="10" Foreground="#888888"
                                                                       VerticalAlignment="Center" Margin="6,0,0,0">
                                                                <TextBlock.Text>
                                                                    <Binding Path="Count" StringFormat="{}{0} files" />
                                                                </TextBlock.Text>
                                                            </TextBlock>
                                                            <TextBlock Text="·" FontSize="10" Foreground="#CCCCCC"
                                                                       VerticalAlignment="Center" Margin="6,0,0,0" />
                                                            <TextBlock Text="{Binding TotalSizeDisplay}" FontSize="10"
                                                                       Foreground="#1565C0" FontWeight="SemiBold"
                                                                       VerticalAlignment="Center" Margin="6,0,0,0" />
                                                        </StackPanel>
                                                    </Expander.Header>
                                                    <!-- Expanded: filter + paged file paths -->
                                                    <StackPanel Margin="24,4,0,6">
                                                        <TextBox Text="{Binding LocationFilter, UpdateSourceTrigger=PropertyChanged, Delay=250}"
                                                                 FontSize="10" Padding="4,3" Margin="0,0,0,4"
                                                                 ToolTip="Filter file paths (case-insensitive)" />
                                                        <ItemsControl ItemsSource="{Binding PagedLocations}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock FontSize="10" Foreground="#666666"
                                                                               TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                                                               Margin="0,1" ToolTip="{Binding FullPath}">
                                                                        <Run Text="📄" /><Run Text=" " /><Run Text="{Binding FullPath, Mode=OneWay}" />
                                                                    </TextBlock>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                            <Button Content="‹ Prev" Click="SubfolderPrevPage_Click"
                                                                    IsEnabled="{Binding CanGoPrevPage}"
                                                                    Padding="6,2" FontSize="10" Cursor="Hand" />
                                                            <Button Content="Next ›" Click="SubfolderNextPage_Click"
                                                                    IsEnabled="{Binding CanGoNextPage}"
                                                                    Padding="6,2" Margin="4,0,0,0" FontSize="10" Cursor="Hand" />
                                                            <TextBlock Text="{Binding PageStatus}" FontSize="10"
                                                                       Foreground="#888888" VerticalAlignment="Center"
                                                                       Margin="10,0,0,0" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Expander>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>

                            <!-- Clear files button + undo + help -->
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="🗑 Clear Selected Files"
                                        Command="{Binding ClearSelectedFileTypesCommand}"
                                        Padding="10,6" FontSize="11" Cursor="Hand"
                                        Foreground="#C62828" FontWeight="SemiBold"
                                        HorizontalAlignment="Stretch"
                                        ToolTip="Delete all files of checked types inside selected result folders" />
                                <Button Grid.Column="1" Content="↶" Command="{Binding UndoLastActionCommand}"
                                        ToolTip="{Binding UndoTooltip}"
                                        Padding="6,3" Margin="4,0,0,0" FontSize="13" Cursor="Hand"
                                        FontWeight="Bold" Foreground="#388E3C" />
                                <ToggleButton Grid.Column="2" Style="{StaticResource HelpButtonStyle}"
                                              Margin="6,0,0,0"
                                              Tag="&lt;h&gt;CLEAR SELECTED FILES&lt;/h&gt;&#x0a;Sends every file whose extension is checked to the Recycle Bin, from inside each selected result folder.&#x0a;&#x0a;&lt;b&gt;What it removes:&lt;/b&gt;&#x0a;• Each matching file found during &lt;b&gt;Scan Folders&lt;/b&gt;&#x0a;• Only files — subfolders are never touched by this action&#x0a;&#x0a;&lt;b&gt;Scope:&lt;/b&gt;&#x0a;• Follows the same &lt;b&gt;Include Subdirectories&lt;/b&gt; setting used during the scan&#x0a;&#x0a;&lt;b&gt;Common uses:&lt;/b&gt;&#x0a;• Purge &lt;b&gt;.log&lt;/b&gt;, &lt;b&gt;.tmp&lt;/b&gt;, &lt;b&gt;.bak&lt;/b&gt; files across many folders&#x0a;• Remove stray &lt;b&gt;.DS_Store&lt;/b&gt; / &lt;b&gt;Thumbs.db&lt;/b&gt;&#x0a;&#x0a;&lt;b&gt;Safety:&lt;/b&gt;&#x0a;• Confirmation dialog shows exact file count + extension list&#x0a;• Skips files that are locked or access-denied&#x0a;&#x0a;&lt;h&gt;Sent to Recycle Bin — restorable from there.&lt;/h&gt;" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Search info -->
                    <Border Background="White" CornerRadius="4" Padding="10" Margin="0,0,0,8"
                            BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Results" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#333333" Margin="0,0,0,6" />
                            <TextBlock FontSize="24" FontWeight="Bold" Foreground="#1565C0" Margin="0,0,0,4">
                                <TextBlock.Text>
                                    <Binding Path="FolderSearchCount" StringFormat="{}{0}" />
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock Text="folders found" FontSize="11" Foreground="#888888" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding FolderSearchStatus}" FontSize="10" Foreground="#666666"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Column 2: File Preview Panel (full window height) -->
        <Border Grid.Column="2" Background="#FAFAFA" CornerRadius="6"
                BorderBrush="#E0E0E0" BorderThickness="1" Padding="12" Margin="4,4,4,4"
                Width="380"
                Visibility="{Binding IsPreviewVisible, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="File Preview" FontSize="16" FontWeight="Bold"
                               Foreground="#1A237E" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="✕ Close" Padding="8,4"
                            Command="{Binding ClosePreviewCommand}"
                            FontSize="11" Cursor="Hand" Foreground="#666666" />
                </Grid>

                <!-- File Info (hidden when no file selected) -->
                <Border Grid.Row="1" Background="White" CornerRadius="4" Padding="8" Margin="0,0,0,8"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PreviewFileName}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="{Binding PreviewFileName}" FontWeight="SemiBold" FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding PreviewFileName}" />
                        <TextBlock Text="{Binding PreviewFileSize}" Foreground="#888888" FontSize="11" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <!-- Preview Content Area -->
                <Border Grid.Row="2" Background="White" CornerRadius="4"
                        BorderBrush="#E0E0E0" BorderThickness="1" Padding="4">
                    <Grid>
                        <!-- Empty State (no file selected) -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PreviewType}" Value="none">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="📄" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,8" />
                            <TextBlock Text="No file selected" FontSize="13" Foreground="#AAAAAA"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Click a file in the list to preview" FontSize="11" Foreground="#CCCCCC"
                                       HorizontalAlignment="Center" Margin="0,4,0,0" />
                        </StackPanel>
                        <!-- Image Preview -->
                        <Image Source="{Binding PreviewImage}" Stretch="Uniform"
                               VerticalAlignment="Top" HorizontalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PreviewType}" Value="image">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>

                        <!-- Video Preview -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PreviewType}" Value="video">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <MediaElement Grid.Row="0" x:Name="VideoPlayer"
                                          Source="{Binding PreviewMediaUri}"
                                          LoadedBehavior="Manual" UnloadedBehavior="Stop"
                                          ScrubbingEnabled="True"
                                          Stretch="Uniform" MediaOpened="MediaElement_MediaOpened" />
                            <StackPanel Grid.Row="1" Margin="0,6,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="▶ Play" Padding="8,4" Margin="0,0,4,0" FontSize="11"
                                            Click="PlayMedia_Click" Cursor="Hand" />
                                    <Button Content="⏸ Pause" Padding="8,4" Margin="0,0,4,0" FontSize="11"
                                            Click="PauseMedia_Click" Cursor="Hand" />
                                    <Button Content="⏹ Stop" Padding="8,4" FontSize="11"
                                            Click="StopMedia_Click" Cursor="Hand" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                    <Button x:Name="VideoMuteButton" Content="🔊" Padding="4,2" FontSize="12"
                                            Click="VideoMute_Click" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0"
                                            ToolTip="Mute / Unmute" />
                                    <Slider x:Name="VideoVolumeSlider" Width="120" Minimum="0" Maximum="1"
                                            Value="{Binding MediaVolume}" VerticalAlignment="Center"
                                            ValueChanged="VideoVolume_Changed"
                                            ToolTip="Volume" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- Audio Preview -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PreviewType}" Value="audio">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="🎵" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12" />
                                <MediaElement x:Name="AudioPlayer"
                                              Source="{Binding PreviewMediaUri}"
                                              LoadedBehavior="Manual" UnloadedBehavior="Stop"
                                              MediaOpened="MediaElement_MediaOpened" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                                    <Button Content="▶ Play" Padding="8,4" Margin="0,0,4,0" FontSize="11"
                                            Click="PlayAudio_Click" Cursor="Hand" />
                                    <Button Content="⏸ Pause" Padding="8,4" Margin="0,0,4,0" FontSize="11"
                                            Click="PauseAudio_Click" Cursor="Hand" />
                                    <Button Content="⏹ Stop" Padding="8,4" FontSize="11"
                                            Click="StopAudio_Click" Cursor="Hand" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                    <Button x:Name="AudioMuteButton" Content="🔊" Padding="4,2" FontSize="12"
                                            Click="AudioMute_Click" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0"
                                            ToolTip="Mute / Unmute" />
                                    <Slider x:Name="AudioVolumeSlider" Width="120" Minimum="0" Maximum="1"
                                            Value="{Binding MediaVolume}" VerticalAlignment="Center"
                                            ValueChanged="AudioVolume_Changed"
                                            ToolTip="Volume" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- Info Card Preview -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PreviewType}" Value="infocard">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="{Binding PreviewText}" FontSize="14"
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       Foreground="#555555" LineHeight="28" />
                        </StackPanel>

                        <!-- Text Preview -->
                        <TextBox Text="{Binding PreviewText, Mode=OneWay}" IsReadOnly="True"
                                 FontFamily="Consolas" FontSize="11"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap" BorderThickness="0"
                                 Background="Transparent">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PreviewType}" Value="text">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <!-- Unsupported Format -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PreviewType}" Value="unsupported">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="📄" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8" />
                            <TextBlock Text="Preview not available for this file type"
                                       Foreground="#999999" FontSize="12" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

    </Grid>
</Window>
