<Window x:Class="WindowsFileManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WindowsFileManager.ViewModels"
        xmlns:helpers="clr-namespace:WindowsFileManager.Helpers"
        Title="Windows File Manager — Duplicate Finder"
        Height="900" Width="1600"
        MinHeight="500" MinWidth="1000"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <helpers:InverseBoolConverter x:Key="InverseBool" />
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <helpers:MiniPreviewConverter x:Key="MiniPreview" />
        <helpers:FileTypeIconConverter x:Key="FileTypeIcon" />
    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="400" />
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Left Column: Controls + Results -->
        <Grid Grid.Column="0" Margin="0,0,8,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Row 0: Target Folders -->
            <GroupBox Grid.Row="0" Header="Target Folders" Padding="8" Margin="0,0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Path input + buttons -->
                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" Text="{Binding NewFolderPath, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="6,4" VerticalContentAlignment="Center"
                                 IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBool}}"
                                 helpers:TextBoxEnterKeyBehavior.Command="{Binding AddFolderByPathCommand}" />

                        <Button Grid.Column="1" Content="Add"
                                Command="{Binding AddFolderByPathCommand}"
                                Padding="12,4" Margin="6,0,0,0"
                                IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBool}}" />

                        <Button Grid.Column="2" Content="Browse..."
                                Command="{Binding AddFolderCommand}"
                                Padding="12,4" Margin="6,0,0,0"
                                IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBool}}" />
                    </Grid>

                    <!-- Folder list -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding TargetPaths}" Margin="0,0,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Button Content="✕"
                                            Command="{Binding DataContext.RemoveFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Padding="4,1" Margin="0,0,6,0"
                                            FontSize="10" Foreground="#C62828" Cursor="Hand"
                                            ToolTip="Remove this folder" />
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center"
                                               FontSize="12" Foreground="#333333"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0">
                        <CheckBox Content="Include subdirectories"
                                  IsChecked="{Binding IncludeSubdirectories}"
                                  IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBool}}"
                                  Margin="0,0,16,0" />
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- Row 1: Action Buttons + Progress -->
            <StackPanel Grid.Row="1" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Scan for Duplicates"
                            Command="{Binding ScanCommand}"
                            Padding="16,6" FontWeight="SemiBold"
                            Margin="0,0,8,0" />

                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Padding="16,6"
                            Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibility}}" />

                    <TextBlock Text="{Binding FilesScanned, StringFormat='Files scanned: {0}'}"
                               VerticalAlignment="Center" Margin="16,0,0,0"
                               Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibility}}" />

                    <CheckBox Content="Mini Preview"
                              IsChecked="{Binding IsMiniPreview}"
                              VerticalAlignment="Center" Margin="16,0,0,0"
                              ToolTip="Show inline thumbnail in the duplicate list" />

                    <CheckBox Content="File Preview"
                              IsChecked="{Binding IsAutoPreview}"
                              VerticalAlignment="Center" Margin="12,0,0,0"
                              ToolTip="Show full file preview panel when clicking a group" />

                    <CheckBox Content="Auto Play"
                              IsChecked="{Binding IsAutoPlay}"
                              VerticalAlignment="Center" Margin="12,0,0,0"
                              ToolTip="Auto-play video/audio. When off, video shows first frame." />
                </StackPanel>

                <ProgressBar Height="6" Margin="0,6,0,0"
                             IsIndeterminate="{Binding IsScanning}"
                             Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>

            <!-- Row 2: Filter Bar + Duplicate Groups List -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Filter Toggle Bar + Sort -->
                <Border Grid.Row="0" Background="#F0F4FF" CornerRadius="4" Padding="8,4" Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="🔽 Filters"
                                Command="{Binding ToggleFilterCommand}"
                                Padding="8,3" FontSize="11" Cursor="Hand"
                                Foreground="#1565C0" Background="Transparent" BorderThickness="0" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0"
                                   FontSize="11" Foreground="#888888">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="Showing {0} of {1} groups">
                                    <Binding Path="FilteredGroupCount" />
                                    <Binding Path="TotalGroupCount" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <TextBlock Grid.Column="2" Text="Sort by:" VerticalAlignment="Center"
                                   FontSize="11" Foreground="#666666" Margin="0,0,6,0" />
                        <ComboBox Grid.Column="3" ItemsSource="{Binding SortOptions}"
                                  SelectedItem="{Binding SelectedSortOption}"
                                  Width="155" FontSize="11" VerticalContentAlignment="Center" />
                    </Grid>
                </Border>

                <!-- Filter Panel (collapsible) -->
                <Border Grid.Row="1" Background="#F8F9FC" CornerRadius="4" Padding="10" Margin="0,0,0,6"
                        BorderBrush="#E0E0E0" BorderThickness="1"
                        Visibility="{Binding IsFilterVisible, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <!-- File Type Filters -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="File Types" FontWeight="SemiBold" FontSize="12"
                                       Foreground="#333333" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Content="Select All"
                                    Command="{Binding ShowAllTypesCommand}"
                                    Padding="6,2" Margin="0,0,4,0" FontSize="10" Cursor="Hand" />
                            <Button Grid.Column="2" Content="Clear All"
                                    Command="{Binding ClearAllTypesCommand}"
                                    Padding="6,2" FontSize="10" Cursor="Hand" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding ExtensionFilters}" Margin="0,0,0,10">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsChecked}" Margin="0,2,12,2" Cursor="Hand">
                                        <CheckBox.Content>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Extension}" FontWeight="SemiBold"
                                                           FontSize="11" Foreground="#1565C0" />
                                                <TextBlock Text="{Binding FileCount, StringFormat=' ({0})'}"
                                                           FontSize="10" Foreground="#888888" />
                                            </StackPanel>
                                        </CheckBox.Content>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Minimum File Size + Min Duplicates Filter -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Min file size:" FontWeight="SemiBold" FontSize="12"
                                       Foreground="#333333" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBox Text="{Binding MinFileSizeText, UpdateSourceTrigger=PropertyChanged}"
                                     Width="80" Padding="4,3" FontSize="11" VerticalContentAlignment="Center" />
                            <ComboBox ItemsSource="{Binding SizeUnits}"
                                      SelectedItem="{Binding SelectedSizeUnit}"
                                      Width="55" Margin="4,0,0,0" FontSize="11"
                                      VerticalContentAlignment="Center" />

                            <TextBlock Text="Min duplicates:" FontWeight="SemiBold" FontSize="12"
                                       Foreground="#333333" VerticalAlignment="Center" Margin="16,0,8,0" />
                            <TextBox Text="{Binding MinDuplicateCount, UpdateSourceTrigger=PropertyChanged}"
                                     Width="45" Padding="4,3" FontSize="11" VerticalContentAlignment="Center" />

                            <Button Content="Apply" Command="{Binding ApplyFileSizeFilterCommand}"
                                    Padding="8,3" Margin="8,0,0,0" FontSize="11" Cursor="Hand" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Duplicate Groups List -->
                <!-- Bulk Action Toggle Bar + Panel -->
                <Border Grid.Row="2" Background="#FFF8E1" CornerRadius="4" Padding="8,4" Margin="0,0,0,4"
                        BorderBrush="#FFE082" BorderThickness="1">
                    <StackPanel>
                        <!-- Toggle bar (always visible when selected) -->
                        <StackPanel Orientation="Horizontal">
                            <Button Content="🔽 Actions"
                                    Command="{Binding ToggleActionsCommand}"
                                    Padding="8,3" FontSize="11" Cursor="Hand"
                                    Foreground="#E65100" Background="Transparent" BorderThickness="0" />
                            <CheckBox Content="Select All" IsChecked="{Binding IsSelectAll}"
                                      VerticalAlignment="Center" Margin="12,0,12,0"
                                      Checked="SelectAll_Checked" Unchecked="SelectAll_Unchecked" />
                            <TextBlock VerticalAlignment="Center"
                                       FontWeight="SemiBold" FontSize="12" Foreground="#E65100">
                                <TextBlock.Text>
                                    <Binding Path="SelectedGroupCount" StringFormat="{}{0} groups selected" />
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>

                        <!-- Expandable action panel -->
                        <StackPanel Margin="0,6,0,0"
                                    Visibility="{Binding IsActionsVisible, Converter={StaticResource BoolToVisibility}}">

                            <!-- SELECT section -->
                            <Border Background="#E8F5E9" CornerRadius="3" Padding="8,6" Margin="0,0,0,6">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="SELECT" FontSize="10" FontWeight="Bold" Foreground="#2E7D32" />
                                        <TextBlock FontSize="10" Foreground="#555555" Margin="8,0,0,0"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Text>
                                                <Binding Path="SelectedFileCount" StringFormat="{}{0} files selected" />
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Select All / By Age / Clear -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Button Content="✓ Select All" Command="{Binding SelectAllFilesCommand}"
                                                Padding="8,3" Margin="0,0,4,0" FontSize="11" Cursor="Hand"
                                                ToolTip="Select all files in selected groups" />
                                        <Button Content="✓ Select Newer" Command="{Binding SelectNewerFilesCommand}"
                                                Padding="8,3" Margin="0,0,4,0" FontSize="11" Cursor="Hand"
                                                ToolTip="Select newer duplicates (keep oldest unselected)" />
                                        <Button Content="✓ Select Older" Command="{Binding SelectOlderFilesCommand}"
                                                Padding="8,3" Margin="0,0,4,0" FontSize="11" Cursor="Hand"
                                                ToolTip="Select older duplicates (keep newest unselected)" />
                                        <Button Content="✕ Clear All" Command="{Binding ClearFileSelectionCommand}"
                                                Padding="8,3" Margin="0,0,0,0" FontSize="11" Cursor="Hand"
                                                Foreground="#888888"
                                                ToolTip="Clear all file selections" />
                                    </StackPanel>

                                    <!-- Custom selection: filename contain -->
                                    <Border BorderBrush="#C8E6C9" BorderThickness="0,1,0,0" Padding="0,4,0,0">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="Filename contain:" FontSize="11" FontWeight="SemiBold"
                                                           VerticalAlignment="Center" Foreground="#2E7D32" Margin="0,0,6,0" Width="105" />
                                                <TextBox Text="{Binding FilenameFilterText, UpdateSourceTrigger=PropertyChanged}"
                                                         Width="200" Padding="4,3" FontSize="11" VerticalContentAlignment="Center" />
                                                <Button Content="✓ Select" Command="{Binding SelectByFilenameCommand}"
                                                        Padding="8,3" Margin="4,0,4,0" FontSize="11" Cursor="Hand"
                                                        ToolTip="Select files whose filename matches the filter" />
                                                <CheckBox Content="Regex" IsChecked="{Binding IsFilenameRegex}"
                                                          VerticalAlignment="Center" FontSize="10" Foreground="#555555"
                                                          ToolTip="Enable regular expression matching for filename" />
                                            </StackPanel>

                                            <!-- Custom selection: filepath contain -->
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Filepath contain:" FontSize="11" FontWeight="SemiBold"
                                                           VerticalAlignment="Center" Foreground="#2E7D32" Margin="0,0,6,0" Width="105" />
                                                <TextBox Text="{Binding FilepathFilterText, UpdateSourceTrigger=PropertyChanged}"
                                                         Width="200" Padding="4,3" FontSize="11" VerticalContentAlignment="Center" />
                                                <Button Content="✓ Select" Command="{Binding SelectByPathCommand}"
                                                        Padding="8,3" Margin="4,0,4,0" FontSize="11" Cursor="Hand"
                                                        ToolTip="Select files whose full path matches the filter" />
                                                <CheckBox Content="Regex" IsChecked="{Binding IsFilepathRegex}"
                                                          VerticalAlignment="Center" FontSize="10" Foreground="#555555"
                                                          ToolTip="Enable regular expression matching for filepath" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- ACTION section -->
                            <Border Background="#FFF3E0" CornerRadius="3" Padding="8,6">
                                <StackPanel>
                                    <TextBlock Text="ACTION" FontSize="10" FontWeight="Bold" Foreground="#E65100"
                                               Margin="0,0,0,4" />
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="🗑 Delete" Command="{Binding DeleteSelectedFilesCommand}"
                                                Padding="8,3" Margin="0,0,8,0" FontSize="11" Cursor="Hand"
                                                Foreground="#C62828"
                                                ToolTip="Delete all selected files" />
                                        <TextBlock Text="Move to:" FontSize="11" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Foreground="#E65100" Margin="0,0,6,0" />
                                        <TextBox Text="{Binding MoveTargetPath, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="230" Padding="4,3" FontSize="11" VerticalContentAlignment="Center" />
                                        <Button Content="Browse..." Command="{Binding BrowseMoveTargetCommand}"
                                                Padding="6,3" Margin="4,0,4,0" FontSize="11" Cursor="Hand" />
                                        <Button Content="📁 Move" Command="{Binding MoveSelectedFilesCommand}"
                                                Padding="8,3" Margin="0,0,0,0" FontSize="11" Cursor="Hand"
                                                Foreground="#1565C0"
                                                ToolTip="Move all selected files to the target folder" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <GroupBox Grid.Row="3" Header="Duplicate Groups" Padding="4">
                <ListView x:Name="DuplicateGroupsList"
                          ItemsSource="{Binding FilteredDuplicateGroups}"
                          SelectedItem="{Binding SelectedDuplicateGroup}"
                          SelectionMode="Extended"
                          SelectionChanged="DuplicateGroups_SelectionChanged"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          VirtualizingPanel.ScrollUnit="Pixel"
                          ScrollViewer.CanContentScroll="True">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <EventSetter Event="PreviewMouseLeftButtonUp" Handler="ListViewItem_Click" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#DDDDDD" BorderThickness="0,0,0,1"
                                    Padding="4,8" Margin="0,0,0,4">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <CheckBox IsChecked="{Binding IsSelected}"
                                                  VerticalAlignment="Center" Margin="0,0,8,0"
                                                  Checked="GroupCheckBox_Changed" Unchecked="GroupCheckBox_Changed" />
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="{Binding Count, StringFormat='{}{0} files'}" />
                                        <TextBlock Text=" — " Foreground="Gray" />
                                        <TextBlock Text="{Binding FormattedFileSize}" Foreground="#1565C0" />
                                        <TextBlock Text=" each — " Foreground="Gray" />
                                        <TextBlock Text="{Binding FormattedWastedSize, StringFormat='wasted: {0}'}"
                                                   Foreground="#C62828" FontWeight="SemiBold" />
                                        <Button Content="{Binding DeleteAllLabel}"
                                                Command="{Binding DataContext.DeleteAllInGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Padding="6,2" Margin="12,0,0,0"
                                                FontSize="11" Cursor="Hand"
                                                Foreground="#C62828" FontWeight="SemiBold" />
                                    </StackPanel>

                                    <!-- Mini Inline Preview -->
                                    <Border Margin="16,2,0,6" Padding="6" CornerRadius="4"
                                            Background="#F5F7FA" BorderBrush="#E8E8E8" BorderThickness="1"
                                            HorizontalAlignment="Left"
                                            Visibility="{Binding DataContext.IsMiniPreview, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}">
                                        <StackPanel Orientation="Horizontal">
                                            <!-- Image thumbnail -->
                                            <Image x:Name="ThumbImg"
                                                   Source="{Binding FirstFilePath, Converter={StaticResource MiniPreview}}"
                                                   Width="60" Height="60" Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="LowQuality"
                                                   Margin="0,0,8,0">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <Trigger Property="Source" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                            <!-- File type icon (only when no thumbnail) -->
                                            <TextBlock Text="{Binding FirstFilePath, Converter={StaticResource FileTypeIcon}}"
                                                       FontSize="32" VerticalAlignment="Center" Margin="0,0,8,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Source, ElementName=ThumbImg}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FirstFileName}" FontSize="11" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="300" />
                                                <TextBlock Text="{Binding FileExtension}" FontSize="10" Foreground="#1565C0" />
                                                <TextBlock Text="{Binding FormattedFileSize}" FontSize="10" Foreground="#888888" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <ItemsControl ItemsSource="{Binding Files}" Margin="16,0,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                                    <CheckBox IsChecked="{Binding IsFileSelected}"
                                                              VerticalAlignment="Center" Margin="0,0,4,0" />
                                                    <Button Content="📂 Open"
                                                            Command="{Binding DataContext.OpenFileLocationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding FilePath}"
                                                            Padding="6,2" Margin="0,0,4,0"
                                                            FontSize="11" Cursor="Hand" />
                                                    <Button Content="🗑 Delete"
                                                            Command="{Binding DataContext.DeleteFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="6,2" Margin="0,0,8,0"
                                                            FontSize="11" Cursor="Hand"
                                                            Foreground="#C62828" />
                                                    <TextBlock Text="{Binding FilePath}"
                                                               Foreground="#333333" FontSize="12"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding FilePath}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </GroupBox>
            </Grid>

            <!-- Row 3: Status Bar + Resource Monitor -->
            <Border Grid.Row="3" Background="#F5F5F5" Padding="8,4" Margin="0,8,0,0"
                    CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Foreground="#666666" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="{Binding ResourceMemory}" Foreground="#1565C0" FontSize="11" Margin="0,0,12,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ResourceCpu}" Foreground="#E65100" FontSize="11" Margin="0,0,12,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ResourceThreads}" Foreground="#666666" FontSize="11" VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Right Column: Analytics Dashboard (full height) -->
        <Border Grid.Column="1" Background="#FAFAFA" CornerRadius="6"
                BorderBrush="#E0E0E0" BorderThickness="1" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel DataContext="{Binding Analytics}">

                    <TextBlock Text="Analytics" FontSize="16" FontWeight="Bold"
                               Foreground="#1A237E" Margin="0,0,0,12" />

                    <!-- Summary Cards -->
                    <Border Background="White" CornerRadius="4" Padding="10" Margin="0,0,0,8"
                            BorderBrush="#E0E0E0" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                                <TextBlock Text="Total Files" Foreground="#999999" FontSize="10" />
                                <TextBlock Text="{Binding TotalFiles, StringFormat=N0}" FontSize="20" FontWeight="Bold" Foreground="#333333" />
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                                <TextBlock Text="Duplicates" Foreground="#999999" FontSize="10" />
                                <TextBlock Text="{Binding TotalDuplicates, StringFormat=N0}" FontSize="20" FontWeight="Bold" Foreground="#C62828" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,8">
                                <TextBlock Text="Groups" Foreground="#999999" FontSize="10" />
                                <TextBlock Text="{Binding DuplicateGroups, StringFormat=N0}" FontSize="20" FontWeight="Bold" Foreground="#1565C0" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                                <TextBlock Text="Scan Time" Foreground="#999999" FontSize="10" />
                                <TextBlock Text="{Binding Duration, StringFormat='{}{0:mm\\:ss\\.f}'}" FontSize="20" FontWeight="Bold" Foreground="#333333" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Text="Wasted Space" Foreground="#999999" FontSize="10" />
                                <TextBlock Text="{Binding FormattedWastedSize}" FontSize="20" FontWeight="Bold" Foreground="#C62828" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1">
                                <TextBlock Text="Duplicate %" Foreground="#999999" FontSize="10" />
                                <TextBlock Text="{Binding DuplicatePercentage, StringFormat='{}{0:F1}%'}" FontSize="20" FontWeight="Bold" Foreground="#E65100" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Wasted Space Bar -->
                    <Border Background="White" CornerRadius="4" Padding="10" Margin="0,0,0,8"
                            BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Wasted vs Total" FontWeight="SemiBold" FontSize="11"
                                       Foreground="#555555" Margin="0,0,0,6" />
                            <Grid Height="20">
                                <Border Background="#E8F5E9" CornerRadius="3" />
                                <Border Background="#EF9A9A" CornerRadius="3"
                                        HorizontalAlignment="Left">
                                    <Border.Width>
                                        <MultiBinding Converter="{x:Static helpers:PercentToWidthConverter.Instance}">
                                            <Binding Path="WastedPercentage" />
                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" />
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Border Width="10" Height="10" Background="#EF9A9A" CornerRadius="2" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding FormattedWastedSize, StringFormat='Wasted: {0}'}" FontSize="10" Foreground="#666666" Margin="0,0,12,0" />
                                <Border Width="10" Height="10" Background="#E8F5E9" CornerRadius="2" Margin="0,0,4,0" />
                                <TextBlock Text="{Binding FormattedTotalSize, StringFormat='Total: {0}'}" FontSize="10" Foreground="#666666" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Top Extensions -->
                    <Border Background="White" CornerRadius="4" Padding="10" Margin="0,0,0,8"
                            BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Top Duplicate Types" FontWeight="SemiBold" FontSize="11"
                                       Foreground="#555555" Margin="0,0,0,6" />
                            <ItemsControl ItemsSource="{Binding TopExtensions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#E3F2FD" CornerRadius="3"
                                                    Padding="4,2" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Extension}" FontSize="10"
                                                           FontWeight="SemiBold" Foreground="#1565C0" />
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding FileCount, StringFormat='{}{0} files'}"
                                                       FontSize="10" Foreground="#888888" Margin="8,0,0,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding FormattedSize}"
                                                       FontSize="10" Foreground="#666666"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Size Distribution -->
                    <Border Background="White" CornerRadius="4" Padding="10"
                            BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Size Distribution" FontWeight="SemiBold" FontSize="11"
                                       Foreground="#555555" Margin="0,0,0,6" />
                            <ItemsControl ItemsSource="{Binding SizeDistribution}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                <TextBlock Text="{Binding Label}" FontSize="10" Foreground="#666666" />
                                                <TextBlock Text="{Binding FileCount, StringFormat=' ({0})'}" FontSize="10" Foreground="#999999" />
                                            </StackPanel>
                                            <Grid Grid.Row="1" Height="8" Margin="0,2,0,0">
                                                <Border Background="#EEEEEE" CornerRadius="2" />
                                                <Border Background="#7986CB" CornerRadius="2"
                                                        HorizontalAlignment="Left">
                                                    <Border.Width>
                                                        <MultiBinding Converter="{x:Static helpers:PercentToWidthConverter.Instance}">
                                                            <Binding Path="BarWidth" />
                                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" />
                                                        </MultiBinding>
                                                    </Border.Width>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Right Column: File Preview Panel -->
        <Border Grid.Column="2" Background="#FAFAFA" CornerRadius="6"
                BorderBrush="#E0E0E0" BorderThickness="1" Padding="12" Margin="8,0,0,0"
                Width="380"
                Visibility="{Binding IsPreviewVisible, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="File Preview" FontSize="16" FontWeight="Bold"
                               Foreground="#1A237E" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="✕ Close" Padding="8,4"
                            Command="{Binding ClosePreviewCommand}"
                            FontSize="11" Cursor="Hand" Foreground="#666666" />
                </Grid>

                <!-- File Info -->
                <Border Grid.Row="1" Background="White" CornerRadius="4" Padding="8" Margin="0,0,0,8"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="{Binding PreviewFileName}" FontWeight="SemiBold" FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding PreviewFileName}" />
                        <TextBlock Text="{Binding PreviewFileSize}" Foreground="#888888" FontSize="11" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <!-- Preview Content Area -->
                <Border Grid.Row="2" Background="White" CornerRadius="4"
                        BorderBrush="#E0E0E0" BorderThickness="1" Padding="4">
                    <Grid>
                        <!-- Image Preview -->
                        <Image Source="{Binding PreviewImage}" Stretch="Uniform"
                               VerticalAlignment="Top" HorizontalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PreviewType}" Value="image">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>

                        <!-- Video Preview -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PreviewType}" Value="video">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <MediaElement Grid.Row="0" x:Name="VideoPlayer"
                                          Source="{Binding PreviewMediaUri}"
                                          LoadedBehavior="Manual" UnloadedBehavior="Stop"
                                          ScrubbingEnabled="True"
                                          Stretch="Uniform" MediaOpened="MediaElement_MediaOpened" />
                            <StackPanel Grid.Row="1" Margin="0,6,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="▶ Play" Padding="8,4" Margin="0,0,4,0" FontSize="11"
                                            Click="PlayMedia_Click" Cursor="Hand" />
                                    <Button Content="⏸ Pause" Padding="8,4" Margin="0,0,4,0" FontSize="11"
                                            Click="PauseMedia_Click" Cursor="Hand" />
                                    <Button Content="⏹ Stop" Padding="8,4" FontSize="11"
                                            Click="StopMedia_Click" Cursor="Hand" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                    <Button x:Name="VideoMuteButton" Content="🔊" Padding="4,2" FontSize="12"
                                            Click="VideoMute_Click" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0"
                                            ToolTip="Mute / Unmute" />
                                    <Slider x:Name="VideoVolumeSlider" Width="120" Minimum="0" Maximum="1"
                                            Value="{Binding MediaVolume}" VerticalAlignment="Center"
                                            ValueChanged="VideoVolume_Changed"
                                            ToolTip="Volume" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- Audio Preview -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PreviewType}" Value="audio">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="🎵" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12" />
                                <MediaElement x:Name="AudioPlayer"
                                              Source="{Binding PreviewMediaUri}"
                                              LoadedBehavior="Manual" UnloadedBehavior="Stop"
                                              MediaOpened="MediaElement_MediaOpened" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                                    <Button Content="▶ Play" Padding="8,4" Margin="0,0,4,0" FontSize="11"
                                            Click="PlayAudio_Click" Cursor="Hand" />
                                    <Button Content="⏸ Pause" Padding="8,4" Margin="0,0,4,0" FontSize="11"
                                            Click="PauseAudio_Click" Cursor="Hand" />
                                    <Button Content="⏹ Stop" Padding="8,4" FontSize="11"
                                            Click="StopAudio_Click" Cursor="Hand" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                    <Button x:Name="AudioMuteButton" Content="🔊" Padding="4,2" FontSize="12"
                                            Click="AudioMute_Click" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0"
                                            ToolTip="Mute / Unmute" />
                                    <Slider x:Name="AudioVolumeSlider" Width="120" Minimum="0" Maximum="1"
                                            Value="{Binding MediaVolume}" VerticalAlignment="Center"
                                            ValueChanged="AudioVolume_Changed"
                                            ToolTip="Volume" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- Info Card Preview (documents, archives, fonts, executables, databases, 3D, non-native images) -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PreviewType}" Value="infocard">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="{Binding PreviewText}" FontSize="14"
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       Foreground="#555555" LineHeight="28" />
                        </StackPanel>

                        <!-- Text Preview -->
                        <TextBox Text="{Binding PreviewText, Mode=OneWay}" IsReadOnly="True"
                                 FontFamily="Consolas" FontSize="11"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap" BorderThickness="0"
                                 Background="Transparent">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PreviewType}" Value="text">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <!-- Unsupported Format -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PreviewType}" Value="unsupported">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="📄" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8" />
                            <TextBlock Text="Preview not available for this file type"
                                       Foreground="#999999" FontSize="12" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
